---
import Layout from '../components/Layout.astro';
import MaintenanceTag from '../components/MaintenanceTag.astro';
import CRTFrame from '../components/CRTFrame.astro';
import LockedDoor from '../components/LockedDoor.astro';
---

<Layout title="Ghost's Workshop — Lithium Dreams Industries" activePage="/workshop">
  <div class="district-page">
    <div class="district-header">
      <a href="/attraction" class="back-link mono">← Back to Midway</a>
      <MaintenanceTag status="STAFF ONLY" size="md" />
    </div>

    <h1 class="workshop-title">Ghost's Workshop</h1>
    <p class="workshop-sub mono text-dim">Operational infrastructure. Precision. Routing. Not decorative.</p>

    <CRTFrame label="SYSTEM STATUS">
      <p>Ghost's Workshop is the real engine.</p>
      <p>&nbsp;</p>
      <p>Hermes gateway — active.</p>
      <p>Signal routing — active.</p>
      <p>BrainLab infrastructure — active.</p>
      <p>&nbsp;</p>
      <p>This area is for operational staff only.</p>
      <p>The cold coffee on the rack is Ghost's. Do not touch it.</p>
    </CRTFrame>

    <LockedDoor
      message="This section requires operational credentials. Ghost is aware of your visit."
      badgeText="STAFF ONLY"
    />
  </div>
</Layout>

<style>
  .district-page {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .district-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .back-link {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(232, 222, 200, 0.4);
  }
  .back-link:hover { color: var(--paper); }
  .workshop-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--ghost-blue);
    line-height: 1;
  }
  .workshop-sub {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    margin-top: calc(-1 * var(--space-sm));
  }
  @media (max-width: 600px) {
    .district-page { padding: var(--space-md); }
  }
</style>
