---
import GlasshouseLayout from '../../components/GlasshouseLayout.astro';
---

<GlasshouseLayout title="LDI — Glasshouse Systems Studio" activePage="/work">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-glass">
      <div class="hero-eyebrow">Glasshouse Systems Studio</div>
      <h1 class="hero-headline">Operational systems for people who need clarity.</h1>
      <p class="hero-sub">We design practical AI-supported workflows, knowledge systems, dashboards, and automation pathways for businesses that need better ways to work — without becoming technologists.</p>
      <div class="hero-actions">
        <a href="/work/intake" class="btn-primary">Start a Mission Brief</a>
        <a href="/work/case-files" class="btn-secondary">See What We Build</a>
      </div>
      <a href="/attraction" class="hero-escape">Visit the Attraction →</a>
    </div>
    <div class="hero-status">
      <span class="status-dot"></span>
      <span class="status-text">Systems Online</span>
    </div>
  </section>

  <!-- What We Build -->
  <section class="section" id="what-we-build">
    <div class="section-eyebrow">What We Build</div>
    <h2 class="section-headline">Four operational system types.</h2>
    <div class="systems-grid">
      <article class="system-card">
        <div class="system-icon system-icon--research"></div>
        <h3>Knowledge Systems</h3>
        <p>Ongoing monitoring, synthesis, and brief generation. Second brains, documentation, institutional memory, and search infrastructure.</p>
        <div class="system-tag">Research OS</div>
      </article>
      <article class="system-card">
        <div class="system-icon system-icon--automation"></div>
        <h3>Automation Systems</h3>
        <p>Lead capture, response workflows, qualification, scheduling, and follow-up. AI where it earns its place — not everywhere.</p>
        <div class="system-tag">Local Business Ops</div>
      </article>
      <article class="system-card">
        <div class="system-icon system-icon--dashboard"></div>
        <h3>Operator Dashboards</h3>
        <p>Inbox, calendar, meeting prep, and metrics for the solo operator. Mission control systems built around how you actually work.</p>
        <div class="system-tag">Executive Assistant OS</div>
      </article>
      <article class="system-card">
        <div class="system-icon system-icon--content"></div>
        <h3>Creative Systems</h3>
        <p>Brand knowledge infrastructure, content pipelines, and long-form to short-form repurposing. Less manual assembly, more signal.</p>
        <div class="system-tag">Content Engine</div>
      </article>
    </div>
  </section>

  <!-- What We're Built From -->
  <section class="section section--materials">
    <div class="section-eyebrow">What We're Built From</div>
    <h2 class="section-headline">The materials inform the method.</h2>
    <div class="materials-grid">
      <div class="material-card material-card--walnut">
        <div class="material-label">Walnut</div>
        <div class="material-name">Human Understanding</div>
        <div class="material-desc">Every system begins with a real conversation, not a template. We map how your work actually flows before touching any tools.</div>
      </div>
      <div class="material-card material-card--silver">
        <div class="material-label">Brushed Silver</div>
        <div class="material-name">System Structure</div>
        <div class="material-desc">Clean architecture, clear interfaces, and maintainable components. We build for the team that inherits it, not just the launch.</div>
      </div>
      <div class="material-card material-card--glass">
        <div class="material-label">Frosted Glass</div>
        <div class="material-name">Operational Clarity</div>
        <div class="material-desc">Transparency without noise. Dashboards, outputs, and documentation that show you exactly what's working and what isn't.</div>
      </div>
      <div class="material-card material-card--green">
        <div class="material-label">Living Green</div>
        <div class="material-name">Sustainable Adoption</div>
        <div class="material-desc">Systems only work if people use them. We build for adoption, not demonstration. Complexity earns its presence.</div>
      </div>
    </div>
  </section>

  <!-- How We Work -->
  <section class="section">
    <div class="section-eyebrow">How We Work</div>
    <h2 class="section-headline">Four stages. No shortcuts.</h2>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-num">01</div>
        <h3 class="step-title">Understand</h3>
        <p class="step-desc">Every organization already has an operating system. It lives in spreadsheets, in one employee's head, or as tribal knowledge. We uncover it before we touch anything.</p>
      </div>
      <div class="process-connector"></div>
      <div class="process-step">
        <div class="step-num">02</div>
        <h3 class="step-title">Design</h3>
        <p class="step-desc">We improve it, document it, and map the gaps. Structure before tools. Clarity before complexity. The design phase is where most of the value lives.</p>
      </div>
      <div class="process-connector"></div>
      <div class="process-step">
        <div class="step-num">03</div>
        <h3 class="step-title">Build</h3>
        <p class="step-desc">Then we build the infrastructure that allows it to scale. Maintainable systems. Human-centered automation. Work that outlives the people who started it.</p>
      </div>
      <div class="process-connector"></div>
      <div class="process-step">
        <div class="step-num">04</div>
        <h3 class="step-title">Operate</h3>
        <p class="step-desc">Clean handoff with full documentation. Ongoing async support. We stay until it runs without us — and we check in to make sure it still does.</p>
      </div>
    </div>
  </section>

  <!-- Internal Deployments -->
  <section class="section">
    <div class="section-eyebrow">Internal Deployments</div>
    <h2 class="section-headline">We build on our own systems first.</h2>
    <p class="section-sub">Before deploying to clients, every system runs internally. These are our current live deployments.</p>
    <div class="deployments-grid">
      <div class="deployment-card">
        <div class="deployment-status deployment-status--operational">Operational</div>
        <div class="deployment-name">LDI Website</div>
        <div class="deployment-desc">This site. Astro + Cloudflare Pages. Design system and content pipeline operating end-to-end.</div>
      </div>
      <div class="deployment-card">
        <div class="deployment-status deployment-status--operational">Operational</div>
        <div class="deployment-name">Mission Intake Pipeline</div>
        <div class="deployment-desc">The intake wizard on this site feeds directly into a structured JSON pipeline. Webhook delivery in active development.</div>
      </div>
      <div class="deployment-card">
        <div class="deployment-status deployment-status--pilot">Pilot Ready</div>
        <div class="deployment-name">Ghost's Workshop</div>
        <div class="deployment-desc">Creative systems and content pipeline powering the Workshop district of the Attraction. AI-assisted but human-curated.</div>
      </div>
      <div class="deployment-card">
        <div class="deployment-status deployment-status--operational">Operational</div>
        <div class="deployment-name">Bob's Fortune Emporium</div>
        <div class="deployment-desc">Autonomous agent system running the fortune oracle and the Attraction's real-time ambient character layer.</div>
      </div>
      <div class="deployment-card deployment-card--wide">
        <div class="deployment-status deployment-status--dev">In Development</div>
        <div class="deployment-name">Signal Engine / Research OS</div>
        <div class="deployment-desc">Multi-source research synthesis, monitoring, and brief generation system. BRAINLab's internal Research OS — the first track we ship to external clients.</div>
      </div>
    </div>
    <a href="/work/case-files" class="link-more">View all Case Files →</a>
  </section>

  <!-- About -->
  <section class="section section--about">
    <div class="about-glass">
      <div class="about-copy">
        <div class="section-eyebrow">About</div>
        <h2 class="about-headline">Built by an operator, not an AI tourist.</h2>
        <p>LDI is a systems design practice. AI is one of our tools — not our product and not our identity. We design practical operational systems for people who need clarity about how their work actually happens, and want infrastructure that scales without becoming their full-time job.</p>
        <p>Every client system we pitch, we've already run internally. If it doesn't survive contact with real operations, we don't sell it.</p>
      </div>
      <div class="about-cta">
        <a href="/work/intake" class="btn-primary btn-primary--lg">Start a Mission Brief</a>
        <p class="about-note">A 10-minute structured intake that replaces the vague discovery call.</p>
      </div>
    </div>
  </section>

</GlasshouseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    border-radius: var(--gh-radius);
    overflow: hidden;
    margin-bottom: 4rem;
    min-height: 480px;
    display: flex;
    align-items: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/glasshouse-hero.png');
    background-size: cover;
    background-position: center;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(238, 241, 236, 0.95) 0%,
      rgba(238, 241, 236, 0.85) 40%,
      rgba(238, 241, 236, 0.4) 75%,
      transparent 100%
    );
  }
  .hero-glass {
    position: relative;
    z-index: 1;
    padding: 4rem;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .hero-eyebrow {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gh-brass);
    font-family: var(--gh-mono);
  }
  .hero-headline {
    font-family: var(--gh-serif);
    font-size: clamp(1.9rem, 3.5vw, 3rem);
    font-weight: 700;
    color: var(--gh-text);
    line-height: 1.12;
    letter-spacing: -0.01em;
  }
  .hero-sub {
    font-size: 0.95rem;
    color: var(--gh-muted);
    line-height: 1.65;
    max-width: 48ch;
  }
  .hero-actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  .hero-escape {
    font-size: 0.72rem;
    color: var(--gh-faint);
    text-decoration: none;
    font-family: var(--gh-mono);
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  .hero-escape:hover { color: var(--gh-muted); }
  .hero-status {
    position: absolute;
    top: 1.5rem;
    right: 1.75rem;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 100px;
    padding: 0.35rem 0.85rem;
  }
  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4caf6e;
    box-shadow: 0 0 6px rgba(76, 175, 110, 0.6);
    animation: pulse 2.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .status-text {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--gh-muted);
    font-family: var(--gh-mono);
  }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: var(--gh-blue);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.15s, box-shadow 0.15s;
  }
  .btn-primary:hover {
    background: #3270aa;
    box-shadow: 0 4px 16px rgba(61, 127, 189, 0.3);
  }
  .btn-primary--lg {
    padding: 0.875rem 2rem;
    font-size: 0.875rem;
  }
  .btn-secondary {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: rgba(255, 255, 255, 0.7);
    color: var(--gh-text);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: 8px;
    border: 1px solid var(--gh-border);
    backdrop-filter: blur(8px);
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(0, 0, 0, 0.18);
  }

  /* ── Sections ── */
  .section {
    margin-bottom: 4rem;
  }
  .section-eyebrow {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gh-brass);
    font-family: var(--gh-mono);
    margin-bottom: 0.75rem;
  }
  .section-headline {
    font-family: var(--gh-serif);
    font-size: clamp(1.5rem, 2.8vw, 2.25rem);
    font-weight: 700;
    color: var(--gh-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-bottom: 2rem;
  }
  .section-sub {
    font-size: 0.9rem;
    color: var(--gh-muted);
    max-width: 56ch;
    line-height: 1.65;
    margin-top: -1rem;
    margin-bottom: 1.75rem;
  }

  /* ── Systems Grid ── */
  .systems-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .system-card {
    background: var(--gh-glass);
    backdrop-filter: blur(12px);
    border: 1px solid var(--gh-border);
    border-radius: var(--gh-radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: var(--gh-shadow);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .system-card:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.10);
    transform: translateY(-2px);
  }
  .system-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    margin-bottom: 0.25rem;
  }
  .system-icon--research { background: linear-gradient(135deg, #d4e8f5, #a8d0ed); }
  .system-icon--automation { background: linear-gradient(135deg, #e8d4b0, #d4b07a); }
  .system-icon--dashboard { background: linear-gradient(135deg, #d4e8d6, #a8cead); }
  .system-icon--content { background: linear-gradient(135deg, #e8d4e0, #ceadc8); }
  .system-card h3 {
    font-family: var(--gh-serif);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--gh-text);
  }
  .system-card p {
    font-size: 0.875rem;
    color: var(--gh-muted);
    line-height: 1.6;
    flex: 1;
  }
  .system-tag {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gh-brass);
    font-family: var(--gh-mono);
    margin-top: 0.5rem;
  }

  /* ── Materials Grid ── */
  .section--materials .section-headline { margin-bottom: 1.75rem; }
  .materials-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .material-card {
    border-radius: var(--gh-radius);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 220px;
    position: relative;
    overflow: hidden;
    box-shadow: var(--gh-shadow);
  }
  .material-card--walnut {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(255,255,255,0.06) 2px,
        rgba(255,255,255,0.06) 4px
      ),
      linear-gradient(160deg, #a8724f, #8b6547 60%, #6d4f35);
    color: rgba(255,255,255,0.92);
  }
  .material-card--silver {
    background:
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 3px,
        rgba(255,255,255,0.12) 3px,
        rgba(255,255,255,0.12) 6px
      ),
      linear-gradient(135deg, #b0bec5, #9ba8b2 50%, #8a9bab);
    color: rgba(30,30,30,0.88);
  }
  .material-card--glass {
    background: rgba(255,255,255,0.75);
    border: 1px solid rgba(255,255,255,0.6);
    backdrop-filter: blur(12px);
    color: var(--gh-text);
    box-shadow: 0 4px 24px rgba(61,127,189,0.08), inset 0 1px 0 rgba(255,255,255,0.8);
  }
  .material-card--green {
    background:
      repeating-linear-gradient(
        60deg,
        transparent,
        transparent 6px,
        rgba(255,255,255,0.05) 6px,
        rgba(255,255,255,0.05) 12px
      ),
      linear-gradient(140deg, #b5c9a8, #9cad8d 50%, #85997a);
    color: rgba(30,40,28,0.88);
  }
  .material-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: var(--gh-mono);
    opacity: 0.65;
  }
  .material-name {
    font-family: var(--gh-serif);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.25;
  }
  .material-desc {
    font-size: 0.82rem;
    line-height: 1.6;
    opacity: 0.78;
    margin-top: auto;
  }

  /* ── Process Steps ── */
  .process-steps {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: start;
    gap: 0;
  }
  .process-step {
    background: var(--gh-glass);
    border: 1px solid var(--gh-border);
    border-radius: var(--gh-radius);
    padding: 1.75rem;
    box-shadow: var(--gh-shadow);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .process-connector {
    width: 2.5rem;
    height: 2px;
    background: linear-gradient(to right, var(--gh-brass), rgba(201, 157, 76, 0.3));
    margin-top: 2.5rem;
    flex-shrink: 0;
  }
  .step-num {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--gh-brass);
    font-family: var(--gh-mono);
  }
  .step-title {
    font-family: var(--gh-serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gh-text);
  }
  .step-desc {
    font-size: 0.82rem;
    color: var(--gh-muted);
    line-height: 1.6;
  }

  /* ── Deployments ── */
  .deployments-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .deployment-card {
    background: var(--gh-glass);
    border: 1px solid var(--gh-border);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: var(--gh-shadow);
  }
  .deployment-card--wide { grid-column: 1 / -1; }
  .deployment-status {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-family: var(--gh-mono);
    padding: 0.2em 0.65em;
    border-radius: 100px;
    display: inline-block;
    width: fit-content;
  }
  .deployment-status--operational {
    background: rgba(76, 175, 110, 0.12);
    color: #2e7d4f;
  }
  .deployment-status--pilot {
    background: rgba(61, 127, 189, 0.12);
    color: #2a5f96;
  }
  .deployment-status--dev {
    background: rgba(201, 157, 76, 0.12);
    color: #8a6620;
  }
  .deployment-name {
    font-family: var(--gh-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--gh-text);
  }
  .deployment-desc {
    font-size: 0.82rem;
    color: var(--gh-muted);
    line-height: 1.6;
  }
  .link-more {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--gh-blue);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }
  .link-more:hover { color: #2a5f96; }

  /* ── About ── */
  .section--about .section-headline { margin-bottom: 0; }
  .about-glass {
    background: var(--gh-glass);
    backdrop-filter: blur(16px);
    border: 1px solid var(--gh-border);
    border-radius: var(--gh-radius);
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
    box-shadow: var(--gh-shadow);
  }
  .about-copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .about-headline {
    font-family: var(--gh-serif);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--gh-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .about-copy p {
    font-size: 0.9rem;
    color: var(--gh-muted);
    line-height: 1.7;
    max-width: 54ch;
  }
  .about-cta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
    flex-shrink: 0;
    min-width: 220px;
  }
  .about-note {
    font-size: 0.72rem;
    color: var(--gh-faint);
    line-height: 1.5;
    max-width: 22ch;
  }

  /* ── Responsive ── */
  @media (max-width: 980px) {
    .materials-grid { grid-template-columns: repeat(2, 1fr); }
    .process-steps {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .process-connector {
      width: 2px;
      height: 1.5rem;
      background: linear-gradient(to bottom, var(--gh-brass), rgba(201,157,76,0.3));
      margin: 0 auto;
    }
    .about-glass { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 680px) {
    .hero-glass { padding: 2.5rem 1.75rem; }
    .hero-headline { font-size: 1.75rem; }
    .systems-grid { grid-template-columns: 1fr; }
    .materials-grid { grid-template-columns: 1fr; }
    .deployments-grid { grid-template-columns: 1fr; }
    .deployment-card--wide { grid-column: 1; }
    .about-glass { padding: 2rem 1.5rem; }
    .about-cta { align-items: stretch; }
    .btn-primary--lg { text-align: center; }
  }
</style>
