---
import GlasshouseLayout from '../../components/GlasshouseLayout.astro';
---

<GlasshouseLayout title="Mission Intake — LDI" activePage="/work/intake">

  <div class="intake-env">

    <!-- Page header -->
    <div class="intake-header">
      <div class="intake-eyebrow">Mission Intake</div>
      <h1 class="intake-title">Brief an operator,<br>not a chatbot.</h1>
      <p class="intake-subtitle">A structured 6-step intake that replaces the vague discovery call.<br>No commitment — just clarity.</p>
    </div>

    <!-- Horizontal stepper -->
    <nav class="intake-stepper" aria-label="Wizard steps">
      <div class="stepper-step active" data-step="0">
        <div class="stepper-dot">
          <span class="stepper-num">1</span>
          <svg class="stepper-check" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l2.8 2.8L10 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="stepper-label">Track</span>
      </div>
      <div class="stepper-line"></div>
      <div class="stepper-step" data-step="1">
        <div class="stepper-dot">
          <span class="stepper-num">2</span>
          <svg class="stepper-check" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l2.8 2.8L10 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="stepper-label">Situation</span>
      </div>
      <div class="stepper-line"></div>
      <div class="stepper-step" data-step="2">
        <div class="stepper-dot">
          <span class="stepper-num">3</span>
          <svg class="stepper-check" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l2.8 2.8L10 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="stepper-label">Outcome</span>
      </div>
      <div class="stepper-line"></div>
      <div class="stepper-step" data-step="3">
        <div class="stepper-dot">
          <span class="stepper-num">4</span>
          <svg class="stepper-check" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l2.8 2.8L10 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="stepper-label">Systems</span>
      </div>
      <div class="stepper-line"></div>
      <div class="stepper-step" data-step="4">
        <div class="stepper-dot">
          <span class="stepper-num">5</span>
          <svg class="stepper-check" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l2.8 2.8L10 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="stepper-label">Scope</span>
      </div>
      <div class="stepper-line"></div>
      <div class="stepper-step" data-step="5">
        <div class="stepper-dot">
          <span class="stepper-num">6</span>
          <svg class="stepper-check" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l2.8 2.8L10 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="stepper-label">Review</span>
      </div>
    </nav>

    <!-- Two-column wizard -->
    <div class="wizard-layout">

      <!-- LEFT: active step content -->
      <main class="wizard-content">
        <form id="missionForm" novalidate>

          <!-- Step 0: Choose Track -->
          <div class="wizard-step active" data-step="0">
            <div class="step-header">
              <h2 class="step-title">Choose your track</h2>
              <p class="step-hint">Select the service that most closely aligns with your primary objective. You can clarify in the brief.</p>
            </div>
            <div class="track-grid">

              <label class="track-card" data-value="Research OS">
                <input type="radio" name="track" value="Research OS" class="track-radio">
                <div class="track-check-badge">
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1.5 5.5l2.8 2.8L9.5 2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="track-icon">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="7.5" cy="7.5" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </div>
                <div class="track-name">Research OS</div>
                <div class="track-desc">Monitoring, synthesis, and knowledge systems.</div>
              </label>

              <label class="track-card" data-value="Content Engine">
                <input type="radio" name="track" value="Content Engine" class="track-radio">
                <div class="track-check-badge">
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1.5 5.5l2.8 2.8L9.5 2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="track-icon">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 13.5l2-6 8-8 2 2-8 8-4 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M11 3l2 2" stroke="currentColor" stroke-width="1.5"/></svg>
                </div>
                <div class="track-name">Content Engine</div>
                <div class="track-desc">Plan, create, repurpose, and publish consistently.</div>
              </label>

              <label class="track-card" data-value="Local Business Ops">
                <input type="radio" name="track" value="Local Business Ops" class="track-radio">
                <div class="track-check-badge">
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1.5 5.5l2.8 2.8L9.5 2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="track-icon">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="3" y="8" width="12" height="8" rx="1" stroke="currentColor" stroke-width="1.5"/><path d="M1 8h16M6 8V5a3 3 0 0 1 6 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </div>
                <div class="track-name">Local Business Ops</div>
                <div class="track-desc">Streamline operations, client experience, and growth.</div>
              </label>

              <label class="track-card" data-value="Executive Assistant OS">
                <input type="radio" name="track" value="Executive Assistant OS" class="track-radio">
                <div class="track-check-badge">
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1.5 5.5l2.8 2.8L9.5 2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="track-icon">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="6" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M3 15c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </div>
                <div class="track-name">Executive Assistant OS</div>
                <div class="track-desc">Delegate with confidence. Stay ahead proactively.</div>
              </label>

              <label class="track-card" data-value="Technical Advisory">
                <input type="radio" name="track" value="Technical Advisory" class="track-radio">
                <div class="track-check-badge">
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1.5 5.5l2.8 2.8L9.5 2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="track-icon">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M14.5 3.5l-3 3m0 0L9 9l-2 4-4 2 2-4 4-2 2.5-2.5m0 0l-3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="track-name">Technical Advisory</div>
                <div class="track-desc">Solve technical challenges and build what matters.</div>
              </label>

              <label class="track-card" data-value="Not Sure Yet">
                <input type="radio" name="track" value="Not Sure Yet" class="track-radio">
                <div class="track-check-badge">
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1.5 5.5l2.8 2.8L9.5 2" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="track-icon">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M9 12v-1m0-2a2 2 0 1 0-2-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </div>
                <div class="track-name">Not Sure Yet</div>
                <div class="track-desc">Use the brief to identify the highest-value start.</div>
              </label>

            </div>
          </div>

          <!-- Step 1: Current Situation -->
          <div class="wizard-step" data-step="1">
            <div class="step-header">
              <h2 class="step-title">Current situation</h2>
              <p class="step-hint">Tell us about the work that's currently costing you the most time or clarity.</p>
            </div>
            <div class="field-stack">
              <div class="field-group">
                <label class="field-label" for="manualWork">What are you doing manually right now?</label>
                <textarea id="manualWork" name="manualWork" class="field-textarea" rows="3" placeholder="The repetitive or high-effort tasks that eat your time..."></textarea>
              </div>
              <div class="field-group">
                <label class="field-label" for="stuckPoint">Where does work get stuck?</label>
                <textarea id="stuckPoint" name="stuckPoint" class="field-textarea" rows="3" placeholder="Handoffs, approvals, missing information, context switching..."></textarea>
              </div>
              <div class="field-group">
                <label class="field-label" for="tools">What tools are currently involved?</label>
                <input type="text" id="tools" name="tools" class="field-input" placeholder="e.g. Google Sheets, Slack, Notion, email...">
              </div>
            </div>
          </div>

          <!-- Step 2: Desired Outcome -->
          <div class="wizard-step" data-step="2">
            <div class="step-header">
              <h2 class="step-title">Desired outcome</h2>
              <p class="step-hint">What would make this worth paying for? Describe the world after the problem is solved.</p>
            </div>
            <div class="field-stack">
              <div class="field-group">
                <label class="field-label" for="desiredOutcome">What should this system deliver?</label>
                <textarea id="desiredOutcome" name="desiredOutcome" class="field-textarea" rows="3" placeholder="What would make this worth paying for?"></textarea>
              </div>
              <div class="field-group">
                <label class="field-label" for="disappear">What should disappear from your workload?</label>
                <textarea id="disappear" name="disappear" class="field-textarea" rows="3" placeholder="Tasks, decisions, or friction you'd eliminate..."></textarea>
              </div>
              <div class="field-group">
                <label class="field-label" for="success30">What would success look like in 30 days?</label>
                <textarea id="success30" name="success30" class="field-textarea" rows="3" placeholder="Describe the outcome you could point to as proof..."></textarea>
              </div>
            </div>
          </div>

          <!-- Step 3: Systems & Context -->
          <div class="wizard-step" data-step="3">
            <div class="step-header">
              <h2 class="step-title">Systems & context</h2>
              <p class="step-hint">Help us understand your environment, team, and comfort level with automation.</p>
            </div>
            <div class="field-stack">
              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="organization">Organization</label>
                  <input type="text" id="organization" name="organization" class="field-input" placeholder="Your organization or practice name">
                </div>
                <div class="field-group">
                  <label class="field-label" for="contact">Your name</label>
                  <input type="text" id="contact" name="contact" class="field-input" placeholder="First and last name">
                </div>
              </div>
              <div class="field-group">
                <label class="field-label" for="email">Email address</label>
                <input type="email" id="email" name="email" class="field-input" placeholder="your@email.com">
              </div>
              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="businessType">Business type</label>
                  <select id="businessType" name="businessType" class="field-select">
                    <option value="">Select...</option>
                    <option value="Solo / Freelance">Solo / Freelance</option>
                    <option value="Small team (2–10)">Small team (2–10)</option>
                    <option value="Mid-size (11–50)">Mid-size (11–50)</option>
                    <option value="Enterprise (50+)">Enterprise (50+)</option>
                    <option value="Non-profit">Non-profit</option>
                  </select>
                </div>
                <div class="field-group">
                  <label class="field-label" for="teamSize">Team size</label>
                  <select id="teamSize" name="teamSize" class="field-select">
                    <option value="">Select...</option>
                    <option value="Just me">Just me</option>
                    <option value="2–5 people">2–5 people</option>
                    <option value="6–15 people">6–15 people</option>
                    <option value="16–50 people">16–50 people</option>
                    <option value="50+ people">50+ people</option>
                  </select>
                </div>
              </div>
              <div class="field-group">
                <label class="field-label" for="aiComfort">AI comfort level</label>
                <select id="aiComfort" name="aiComfort" class="field-select">
                  <option value="">Select...</option>
                  <option value="Curious but new">Curious but new</option>
                  <option value="Some exposure">Some exposure</option>
                  <option value="Active user">Active user</option>
                  <option value="Building with AI">Building with AI</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Step 4: Scope -->
          <div class="wizard-step" data-step="4">
            <div class="step-header">
              <h2 class="step-title">Scope</h2>
              <p class="step-hint">Help us understand the scale and shape of this engagement.</p>
            </div>
            <div class="field-stack">
              <div class="field-row">
                <div class="field-group">
                  <label class="field-label" for="timeline">Timeline</label>
                  <select id="timeline" name="timeline" class="field-select">
                    <option value="">Select...</option>
                    <option value="ASAP">ASAP</option>
                    <option value="Within 30 days">Within 30 days</option>
                    <option value="Within 90 days">Within 90 days</option>
                    <option value="Exploring for now">Exploring for now</option>
                  </select>
                </div>
                <div class="field-group">
                  <label class="field-label" for="budget">Budget comfort</label>
                  <select id="budget" name="budget" class="field-select">
                    <option value="">Select...</option>
                    <option value="Under $200/mo">Under $200/mo</option>
                    <option value="$200–500/mo">$200–500/mo</option>
                    <option value="$500–1,000/mo">$500–1,000/mo</option>
                    <option value="$1,000+ / project-based">$1,000+ / project-based</option>
                  </select>
                </div>
              </div>
              <div class="field-group">
                <label class="field-label" for="pilot">What's the smallest useful pilot?</label>
                <textarea id="pilot" name="pilot" class="field-textarea" rows="3" placeholder="Minimum scope that would still prove real value..."></textarea>
              </div>
              <div class="field-group">
                <label class="field-label" for="followUp">Preferred follow-up</label>
                <select id="followUp" name="followUp" class="field-select">
                  <option value="">Select...</option>
                  <option value="Async email">Async email</option>
                  <option value="Short video call">Short video call</option>
                  <option value="Written proposal first">Written proposal first</option>
                  <option value="No follow-up — just sending the brief">No follow-up — just sending the brief</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Step 5: Review -->
          <div class="wizard-step" data-step="5">
            <div class="step-header">
              <h2 class="step-title">Review your mission brief</h2>
              <p class="step-hint">Your brief is ready. Copy, download, or submit it below.</p>
            </div>
            <div class="submit-notice hidden" id="submitNotice">
              <div class="submit-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="#4a8c5c" stroke-width="1.5"/><path d="M6 10l3 3 5-5" stroke="#4a8c5c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <strong>Mission brief received.</strong>
                <span>We'll be in touch based on your preferred follow-up method.</span>
              </div>
            </div>
            <div class="review-summary" id="reviewSummary"></div>
            <div class="review-actions">
              <button type="button" id="copyJsonBtn" class="btn-action">Copy JSON</button>
              <button type="button" id="downloadJsonBtn" class="btn-action">Download JSON</button>
              <button type="button" id="resetBtn" class="btn-action btn-action--ghost">Reset Brief</button>
            </div>
          </div>

        </form>
      </main>

      <!-- RIGHT: live Mission Brief tracker dashboard -->
      <aside class="wizard-tracker">
        <div class="tracker-card">

          <div class="tracker-top">
            <div class="tracker-identity">
              <div class="tracker-eyebrow">Mission Brief</div>
              <div class="tracker-ref" id="trackerRef">Generating...</div>
            </div>
            <div class="tracker-ring-wrap">
              <svg width="52" height="52" viewBox="0 0 52 52" fill="none" aria-hidden="true">
                <circle cx="26" cy="26" r="19" stroke="#e8ece8" stroke-width="2.5"/>
                <circle cx="26" cy="26" r="19"
                  stroke="#3d7fbd"
                  stroke-width="2.5"
                  stroke-dasharray="119.38"
                  stroke-dashoffset="99.48"
                  stroke-linecap="round"
                  transform="rotate(-90 26 26)"
                  id="progressRing"/>
              </svg>
              <div class="tracker-ring-label">
                <span id="progressPct">17%</span>
              </div>
            </div>
          </div>

          <div class="tracker-step-label" id="progressStepLabel">Step 1 of 6 — Track</div>

          <div class="tracker-rule"></div>

          <div class="tracker-service-row">
            <div class="tracker-micro-label">Service Track</div>
            <div class="tracker-track-pill" id="trackerTrack" data-set="false">Not selected</div>
          </div>

          <div class="tracker-rule"></div>

          <div class="tracker-fields">
            <div class="tracker-field-row">
              <div class="tracker-dot" id="tdot-situation" data-filled="false"></div>
              <div class="tracker-field-body">
                <div class="tracker-micro-label">Situation</div>
                <div class="tracker-field-val" id="tval-situation">Not provided</div>
              </div>
            </div>
            <div class="tracker-field-row">
              <div class="tracker-dot" id="tdot-outcome" data-filled="false"></div>
              <div class="tracker-field-body">
                <div class="tracker-micro-label">Outcome</div>
                <div class="tracker-field-val" id="tval-outcome">Not provided</div>
              </div>
            </div>
            <div class="tracker-field-row">
              <div class="tracker-dot" id="tdot-systems" data-filled="false"></div>
              <div class="tracker-field-body">
                <div class="tracker-micro-label">Systems</div>
                <div class="tracker-field-val" id="tval-systems">Not provided</div>
              </div>
            </div>
            <div class="tracker-field-row">
              <div class="tracker-dot" id="tdot-scope" data-filled="false"></div>
              <div class="tracker-field-body">
                <div class="tracker-micro-label">Scope</div>
                <div class="tracker-field-val" id="tval-scope">Not provided</div>
              </div>
            </div>
          </div>

          <div class="tracker-rule"></div>

          <div class="tracker-timeline hidden" id="trackerTimelineRow">
            <div class="tracker-micro-label">Timeline</div>
            <div class="tracker-timeline-val" id="trackerTimelineVal">—</div>
            <div class="tracker-rule"></div>
          </div>

          <div class="tracker-next-row">
            <div class="tracker-micro-label">Next Step</div>
            <div class="tracker-next-val" id="trackerNext">Current Situation</div>
          </div>

          <details class="tracker-json-block" id="jsonBlock">
            <summary class="tracker-json-toggle">JSON Output</summary>
            <pre class="tracker-json-pre" id="jsonOutput">{}</pre>
            <div class="tracker-json-actions">
              <button type="button" id="copyJsonBtn" class="btn-json-action">Copy</button>
              <button type="button" id="downloadJsonBtn" class="btn-json-action">Download</button>
            </div>
          </details>

        </div>
      </aside>

    </div><!-- /wizard-layout -->

    <!-- Sticky bottom nav bar -->
    <div class="wizard-sticky-nav">
      <div class="sticky-left">
        <a href="/work" class="btn-ghost-nav">← Studio</a>
        <button type="button" id="backBtn" class="btn-ghost-nav hidden">← Back</button>
      </div>
      <div class="sticky-center">
        <span class="confidence-text" id="confidenceText">Select a track to begin your mission brief.</span>
      </div>
      <div class="sticky-right">
        <button type="button" id="nextBtn" class="btn-continue-nav">Continue to Situation →</button>
        <button type="submit" form="missionForm" id="submitBtn" class="btn-continue-nav hidden">Submit Mission Brief</button>
      </div>
    </div>

  </div><!-- /intake-env -->

</GlasshouseLayout>

<style>
  /* ── Environment wrapper ── */
  .intake-env {
    position: relative;
    padding-bottom: 90px;
  }

  /* ── Page header ── */
  .intake-header {
    margin-bottom: 2rem;
    max-width: 560px;
    position: relative;
    z-index: 1;
  }
  .intake-eyebrow {
    font-size: 0.60rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gh-silver);
    margin-bottom: 0.75rem;
  }
  .intake-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--gh-text);
    margin-bottom: 0.75rem;
  }
  .intake-subtitle {
    font-size: 0.88rem;
    color: var(--gh-muted);
    line-height: 1.6;
  }

  /* ── Horizontal stepper ── */
  .intake-stepper {
    display: flex;
    align-items: center;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
    overflow-x: auto;
    padding-bottom: 2px;
  }

  .stepper-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    cursor: default;
    flex-shrink: 0;
    min-width: 52px;
  }

  .stepper-dot {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 2px solid #d4d9d4;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .stepper-num {
    font-size: 0.68rem;
    font-weight: 700;
    color: #b0b8b0;
    line-height: 1;
  }

  .stepper-check {
    display: none;
    color: white;
  }

  .stepper-label {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #b0b8b0;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  /* Active step */
  .stepper-step.active .stepper-dot {
