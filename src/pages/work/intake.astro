</style>

<script>
  // ── DOM refs ──
  const steps = Array.from(document.querySelectorAll('.wizard-step')) as HTMLElement[];
  const stepperDots = Array.from(document.querySelectorAll('.stepper-step')) as HTMLElement[];
  const backBtn = document.getElementById('backBtn') as HTMLButtonElement;
  const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const form = document.getElementById('missionForm') as HTMLFormElement;
  const jsonOutput = document.getElementById('jsonOutput') as HTMLPreElement;
  const progressRing = document.getElementById('progressRing') as SVGCircleElement;
  const progressPct = document.getElementById('progressPct') as HTMLElement;
  const progressStepLabel = document.getElementById('progressStepLabel') as HTMLElement;
  const trackerRef = document.getElementById('trackerRef') as HTMLElement;
  const trackerTrack = document.getElementById('trackerTrack') as HTMLElement;
  const trackerNext = document.getElementById('trackerNext') as HTMLElement;
  const trackerTimelineRow = document.getElementById('trackerTimelineRow') as HTMLElement;
  const trackerTimelineVal = document.getElementById('trackerTimelineVal') as HTMLElement;
  const submitNotice = document.getElementById('submitNotice') as HTMLElement;
  const reviewSummary = document.getElementById('reviewSummary') as HTMLElement;
  const confidenceText = document.getElementById('confidenceText') as HTMLElement;

  const STEP_NAMES = ['Track', 'Situation', 'Outcome', 'Systems', 'Scope', 'Review'];
  const NEXT_NAMES = ['Current Situation', 'Desired Outcome', 'Systems & Context', 'Scope', 'Review & Submit', '—'];
  const CONTINUE_LABELS = [
    'Continue to Situation',
    'Continue to Outcome',
    'Continue to Systems',
    'Continue to Scope',
    'Continue to Review',
    'Submit Mission Brief',
  ];
  const CONFIDENCE = [
    'Select a track to begin your mission brief.',
    'No commitment — just clarity. Takes 5–7 minutes.',
    'No commitment — just clarity. Takes 5–7 minutes.',
    'No commitment — just clarity. Takes 5–7 minutes.',
    'No commitment — just clarity. Takes 5–7 minutes.',
    'Ready to submit. Your brief will be delivered within 24 hours.',
  ];

  const TRACK_DESC: Record<string, string> = {
    'Research OS': 'Turn research, synthesis, and insights into repeatable clarity and decisions.',
    'Content Engine': 'Plan, create, repurpose, and publish high-value content with consistency.',
    'Local Business Ops': 'Streamline day-to-day operations, client experience, and growth systems.',
    'Executive Assistant OS': 'Delegate with confidence and stay ahead with proactive support.',
    'Technical Advisory': 'Solve technical challenges, evaluate options, and build what matters.',
    'Not Sure Yet': 'Use the brief to identify the highest-value starting point.',
  };

  const RING_CIRC = 119.38; // 2π × 19
  const REF = `LDI-${new Date().getFullYear()}-${String(Math.floor(Math.random() * 9999)).padStart(4, '0')}`;
  trackerRef.textContent = REF;

  let currentStep = 0;

  // ── Data helpers ──
  function formData(): Record<string, string> {
    const d: Record<string, string> = {};
    new FormData(form).forEach((v, k) => { d[k] = v as string; });
    return d;
  }

  function buildBrief() {
    const d = formData();
    return {
      reference: REF,
      track: d.track || 'Not selected',
      organization: d.organization || '',
      contact: d.contact || '',
      email: d.email || '',
      situation: { manualWork: d.manualWork || '', stuckPoint: d.stuckPoint || '', tools: d.tools || '' },
      desiredOutcome: { outcome: d.desiredOutcome || '', removeFromWorkload: d.disappear || '', success30Days: d.success30 || '' },
      systems: { businessType: d.businessType || '', teamSize: d.teamSize || '', aiComfort: d.aiComfort || '' },
      scope: { timeline: d.timeline || '', budget: d.budget || '', pilot: d.pilot || '', followUp: d.followUp || '' },
      generatedAt: new Date().toISOString(),
      source: 'LDI Mission Intake',
      status: 'Mission Brief Draft',
    };
  }

  // ── Tracker field update ──
  function setTrackerField(id: string, value: string | undefined) {
    const dot = document.getElementById(`tdot-${id}`) as HTMLElement;
    const val = document.getElementById(`tval-${id}`) as HTMLElement;
    const filled = !!value;
    dot.dataset.filled = String(filled);
    val.dataset.filled = String(filled);
    val.textContent = filled ? (value!.length > 48 ? value!.slice(0, 45) + '…' : value!) : 'Not provided';
  }

  // ── Stepper sync ──
  function syncStepper() {
    stepperDots.forEach((el, i) => {
      el.classList.remove('active', 'completed');
      if (i === currentStep) el.classList.add('active');
      else if (i < currentStep) el.classList.add('completed');
    });
  }

  // ── Full tracker update ──
  function updateTracker() {
    const d = formData();
    const pct = Math.round(((currentStep + 1) / steps.length) * 100);
    const offset = RING_CIRC * (1 - pct / 100);
    progressRing.style.strokeDashoffset = String(offset);
    progressPct.textContent = `${pct}%`;
    progressStepLabel.textContent = `Step ${currentStep + 1} of 6 — ${STEP_NAMES[currentStep]}`;

    // Track pill
    const track = d.track || '';
    trackerTrack.textContent = track || 'Not selected';
    trackerTrack.dataset.set = track ? 'true' : 'false';

    // Fields
    setTrackerField('situation', d.stuckPoint || d.manualWork || undefined);
    setTrackerField('outcome', d.desiredOutcome || d.success30 || undefined);
    setTrackerField('systems', [d.aiComfort, d.teamSize].filter(Boolean).join(' · ') || undefined);
    setTrackerField('scope', [d.timeline, d.budget].filter(Boolean).join(' / ') || undefined);

    // Timeline
    if (d.timeline) {
      trackerTimelineRow.classList.remove('hidden');
      trackerTimelineVal.textContent = d.timeline;
    }

    // Next step
    trackerNext.textContent = NEXT_NAMES[currentStep] || '—';

    // Continue button
    const isLast = currentStep === steps.length - 1;
    nextBtn.textContent = `${CONTINUE_LABELS[currentStep]} →`;
    nextBtn.classList.toggle('hidden', isLast);
    submitBtn.classList.toggle('hidden', !isLast);

    // Back button
    backBtn.classList.toggle('hidden', currentStep === 0);
    backBtn.disabled = currentStep === 0;

    // Confidence text
    confidenceText.textContent = CONFIDENCE[currentStep] || CONFIDENCE[1];

    // JSON
    jsonOutput.textContent = JSON.stringify(buildBrief(), null, 2);

    // Review summary
    if (currentStep === 5) populateReview(d);
  }

  function populateReview(d: Record<string, string>) {
    const brief = buildBrief();
    const field = (key: string, val: string) =>
      `<div class="review-field"><span class="review-key">${key}</span><span class="review-val">${val || '—'}</span></div>`;
    reviewSummary.innerHTML = [
      field('Reference', brief.reference),
      field('Track', d.track),
      field('Organization', d.organization),
      field('Contact', [d.contact, d.email].filter(Boolean).join(' · ')),
      field('Situation', d.stuckPoint || d.manualWork),
      field('Outcome', d.desiredOutcome),
      field('Timeline', d.timeline),
      field('Budget', d.budget),
      field('Follow-up', d.followUp),
    ].join('');
  }

  // ── Step navigation ──
  function setStep(next: number) {
    currentStep = Math.max(0, Math.min(steps.length - 1, next));
    steps.forEach((s, i) => s.classList.toggle('active', i === currentStep));
    syncStepper();
    updateTracker();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── Track card selection ──
  document.querySelectorAll('.track-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.track-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      const radio = card.querySelector('input') as HTMLInputElement;
      radio.checked = true;
      updateTracker();
    });
  });

  // ── Navigation ──
  nextBtn.addEventListener('click', () => setStep(currentStep + 1));
  backBtn.addEventListener('click', () => setStep(currentStep - 1));

  // ── Form live update ──
  form.addEventListener('input', updateTracker);
  form.addEventListener('change', updateTracker);

  // ── Submit ──
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    updateTracker();
    submitNotice.classList.remove('hidden');
    submitNotice.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  // ── Copy / Download (tracker panel + review step share same buttons) ──
  function handleCopy() {
    updateTracker();
    navigator.clipboard.writeText(jsonOutput.textContent || '').then(() => {
      document.querySelectorAll('.btn-json-action, #copyJsonBtn').forEach(btn => {
        const el = btn as HTMLButtonElement;
        if (el.textContent?.includes('Copy')) {
          const prev = el.textContent;
          el.textContent = 'Copied!';
          setTimeout(() => { el.textContent = prev; }, 2000);
        }
      });
    });
  }

  function handleDownload() {
    updateTracker();
    const blob = new Blob([jsonOutput.textContent || ''], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${REF}.json`;
    a.click();
    URL.revokeObjectURL(url);
  }

  document.querySelectorAll('#copyJsonBtn').forEach(btn => btn.addEventListener('click', handleCopy));
  document.querySelectorAll('#downloadJsonBtn').forEach(btn => btn.addEventListener('click', handleDownload));

  document.getElementById('resetBtn')?.addEventListener('click', () => {
    form.reset();
    document.querySelectorAll('.track-card').forEach(c => c.classList.remove('selected'));
    submitNotice.classList.add('hidden');
    setStep(0);
  });

  // ── Init ──
  setStep(0);
</script>
