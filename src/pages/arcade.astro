---
import Layout from '../components/Layout.astro';
import MuseumPlaque from '../components/MuseumPlaque.astro';
import MaintenanceTag from '../components/MaintenanceTag.astro';
import CRTFrame from '../components/CRTFrame.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="Arcade — Lithium Dreams Industries" activePage="/arcade">
  <div class="page-hero" style="background-image: url('/arcade-hero.png')">
    <!-- NOIZE RAZE neon sign Easter egg — upper-right of arcade image -->
    <a href="/workshop" class="noize-raze-signal" aria-label="Signal detected" tabindex="-1"></a>
    <div class="page-hero-fade"></div>
  </div>
  <div class="district-page">
    <div class="district-header">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Midway', href: '/attraction' },
        { label: 'Arcade' },
      ]} />
      <MaintenanceTag status="FLICKERING" size="md" />
    </div>

    <MuseumPlaque accession="ARC-001" title="Arcade" subtitle="Project cabinets, experimental builds, and things that almost work." />

    <div class="district-content">
      <CRTFrame label="ARCADE DIRECTORY" standby={true}>
        <p>Loading cabinet index...</p>
        <p>Please do not unplug the cabinet in the corner.</p>
      </CRTFrame>

      <div class="cabinet-row">
        <div class="cabinet-placeholder">
          <span class="cabinet-label mono">CABINET 01</span>
          <span class="cabinet-name">// PROJECT PENDING</span>
          <span class="cabinet-status mono text-dim">OUT OF ORDER / STILL RUNNING</span>
        </div>
        <div class="cabinet-placeholder cabinet-joust">
          <span class="cabinet-label mono">CABINET 02</span>
          <span class="cabinet-name">JERSEY DEVIL JOUST</span>
          <span class="cabinet-status mono text-dim">OUT OF ORDER / STILL RUNNING</span>
          <a href="/workshop" class="ghost-signal" aria-label="Signal detected" tabindex="-1"></a>
        </div>
        <div class="cabinet-placeholder">
          <span class="cabinet-label mono">CABINET 03</span>
          <span class="cabinet-name">// PROJECT PENDING</span>
          <span class="cabinet-status mono text-dim">OUT OF ORDER / STILL RUNNING</span>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page-hero {
    width: 100%;
    min-height: 50vh;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .page-hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(to bottom, transparent, var(--ldi-black));
  }
  /* NOIZE RAZE neon sign — upper-right of arcade hero image */
  .noize-raze-signal {
    position: absolute;
    left: 64%;
    top: 7%;
    width: 15%;
    height: 17%;
    display: block;
    text-decoration: none;
    cursor: default;
    z-index: 2;
  }
  .noize-raze-signal:hover {
    cursor: crosshair;
    background: rgba(77, 184, 212, 0.07);
    box-shadow: inset 0 0 18px rgba(77, 184, 212, 0.05);
  }

  .district-page {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .district-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .back-link {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(232, 222, 200, 0.4);
  }
  .back-link:hover { color: var(--paper); }
  .district-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .cabinet-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  .cabinet-placeholder {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: var(--space-lg) var(--space-md);
    border: 1px solid rgba(255,255,255,0.07);
    background: var(--road-asphalt);
    min-height: 150px;
    justify-content: center;
  }
  .cabinet-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: rgba(77, 184, 212, 0.5);
    text-transform: uppercase;
  }
  .cabinet-joust { position: relative; }
  .ghost-signal {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 28%;
    display: block;
    cursor: default;
    text-decoration: none;
  }
  .ghost-signal:hover { cursor: crosshair; }
  .cabinet-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: rgba(232, 222, 200, 0.25);
  }
  .cabinet-status {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  @media (max-width: 600px) {
    .cabinet-row { grid-template-columns: 1fr; }
    .district-page { padding: var(--space-md); }
  }
</style>
