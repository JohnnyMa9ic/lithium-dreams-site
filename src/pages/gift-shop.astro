---
import Layout from '../components/Layout.astro';
import MuseumPlaque from '../components/MuseumPlaque.astro';
import MaintenanceTag from '../components/MaintenanceTag.astro';
import EmployeeNotice from '../components/EmployeeNotice.astro';
---

<Layout title="Gift Shop — Lithium Dreams Industries" activePage="/gift-shop">
  <div class="district-page">
    <div class="district-header">
      <a href="/attraction" class="back-link mono">← Back to Midway</a>
      <MaintenanceTag status="OPEN" size="md" />
    </div>

    <MuseumPlaque accession="GS-001" title="Gift Shop" subtitle="Souvenirs, field notes, stickers, and objects we are legally allowed to sell." />

    <div class="district-content">
      <EmployeeNotice heading="Notice to Visitors">
        <p>The gift shop is open. The register is staffed by someone who has been here a very long time.</p>
        <p>Please do not ask about the clearance bin in the back.</p>
      </EmployeeNotice>

      <div class="shop-grid">
        <div class="shop-item">
          <div class="item-badge item-badge--soldout mono">SOLD OUT</div>
          <p class="item-name">Field Notes Vol. 1 — The Crossroads</p>
          <p class="item-desc mono text-dim">// 48pp · hand-numbered · last batch</p>
        </div>
        <div class="shop-item">
          <p class="item-name">Warden Patch — Standard Issue</p>
          <p class="item-desc mono text-dim">// embroidered · 3" · iron-on · limited</p>
          <p class="item-price mono">$8</p>
        </div>
        <div class="shop-item">
          <div class="item-badge item-badge--soldout mono">SOLD OUT</div>
          <p class="item-name">Realm Record No. 1 — Mothman Signal</p>
          <p class="item-desc mono text-dim">// 7" · lathe cut · 150 copies · gone</p>
        </div>
      </div>
      <div class="backroom-teaser mono text-dim">
        // BACKROOM INVENTORY: items not listed here exist. ask at the counter. some require clearance.
      </div>
    </div>
  </div>
</Layout>

<style>
  .district-page {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-xl) var(--content-pad);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .district-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .back-link {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(232, 222, 200, 0.4);
  }
  .back-link:hover { color: var(--paper); }
  .district-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .placeholder-shelf {
    padding: var(--space-lg);
    border: 1px dashed rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.75rem;
  }
  .shop-grid { display: flex; flex-direction: column; gap: var(--space-md); }
  .shop-item { position: relative; padding: var(--space-md); border: 1px solid var(--ldi-border, rgba(255,255,255,0.06)); display: flex; flex-direction: column; gap: 0.3rem; }
  .item-badge { font-size: 0.6rem; letter-spacing: 0.15em; display: inline-block; padding: 0.15rem 0.5rem; margin-bottom: 0.25rem; }
  .item-badge--soldout { color: var(--ldi-crimson, #c0281a); border: 1px solid var(--ldi-crimson, #c0281a); opacity: 0.7; }
  .item-name { font-family: var(--font-display, var(--ldi-font-display)); font-size: var(--ldi-text-lg, 1.25rem); letter-spacing: 0.05em; color: var(--paper, var(--ldi-text-primary)); }
  .item-desc { font-size: 0.68rem; letter-spacing: 0.08em; }
  .item-price { font-size: 0.75rem; letter-spacing: 0.1em; color: var(--ldi-amber, #d4820a); }
  .backroom-teaser { font-size: 0.65rem; letter-spacing: 0.08em; padding: var(--space-sm) 0; border-top: 1px solid rgba(255,255,255,0.04); }
</style>
