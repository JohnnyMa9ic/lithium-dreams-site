---
import Layout from '../../components/Layout.astro';
---

<Layout
  title="The Cathedral — Lithium Dreams Industries"
  description="You were told not to follow the roots toward the Cathedral. This is what happens when you do."
>
  <div class="cathedral-wrap">
    <div class="cathedral-inner">
      <p class="cath-eyebrow mono">Sector — Unclassified</p>
      <h1 class="cath-title">The Cathedral</h1>
      <p class="cath-warning mono">You were told not to follow the roots.</p>
      <div class="cath-body">
        <p>This sector does not appear on the official venue map. The Warden has flagged this location for containment review since Y07. The organ plays music that has not been scheduled.</p>
        <p>No incidents have been formally recorded here. This is because incidents that originate here are reclassified before they reach the log. The Warden knows. The Warden is not elaborating at this time.</p>
        <p>You should not have followed the roots.</p>
      </div>
      <div class="cath-footer">
        <span class="cath-status mono">Status: [REDACTED]</span>
        <a href="/deep-garden" class="cath-back mono">← Return to the Garden</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .cathedral-wrap {
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ldi-black);
    padding: var(--space-xl);
  }

  .cathedral-inner {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-xl);
    border: 1px solid rgba(77,184,212,0.08);
    background: rgba(77,184,212,0.02);
  }

  .cath-eyebrow {
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    color: rgba(77,184,212,0.4);
    text-transform: uppercase;
  }

  .cath-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5.5rem);
    color: var(--paper);
    line-height: 0.92;
    opacity: 0.7;
  }

  .cath-warning {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: rgba(77,184,212,0.55);
    border-left: 2px solid rgba(77,184,212,0.2);
    padding-left: var(--space-md);
    font-style: italic;
  }

  .cath-body {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .cath-body p {
    font-family: var(--font-body);
    font-size: 0.82rem;
    line-height: 1.8;
    color: rgba(232,222,200,0.45);
    letter-spacing: 0.02em;
  }

  .cath-body p:last-child {
    color: rgba(77,184,212,0.4);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .cath-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(77,184,212,0.06);
  }

  .cath-status {
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    color: rgba(77,184,212,0.25);
    text-transform: uppercase;
  }

  .cath-back {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232,222,200,0.25);
    text-decoration: none;
    transition: color 0.15s;
  }

  .cath-back:hover { color: rgba(232,222,200,0.6); }
</style>
