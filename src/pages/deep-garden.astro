    font-style: normal;
  }

  /* ── Responsive ── */
  @media (max-width: 1050px) {
    .depth-marker { display: none; }
    .status-card {
      position: static;
      width: 100%;
      max-width: 520px;
    }
    .section-head--split,
    .planting-station,
    .note-grid,
    .doorway-grid { grid-template-columns: 1fr; }
    .seed-preview-panel { position: static; }
    .artifact-grid { grid-template-columns: repeat(2, 1fr); }
    .descent-copy {
      left: 1rem;
      right: 1rem;
      bottom: 2rem;
      width: auto;
    }
  }
  @media (max-width: 680px) {
    .hero-text h1 { font-size: 4rem; }
    .artifact-grid { grid-template-columns: 1fr; }
    .descent-stage { height: 360vh; }
    .root-map { min-height: 580px; }
    .root-node {
      font-size: 0.6rem;
      white-space: normal;
      max-width: 100px;
      text-align: center;
    }
    .note-grid blockquote { min-height: unset; }
    .doorway-grid { grid-template-columns: 1fr 1fr; }
    .doorway-card--danger { grid-column: 1 / -1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .descent-stage { height: auto; }
    .descent-viewport { position: relative; height: auto; min-height: 100vh; }
    .cutaway-image, .deep-image, .roots-layer, .signal-layer { opacity: 0.35 !important; }
    .surface-image { opacity: 0.5 !important; }
    .descent-copy { position: relative; opacity: 1 !important; transform: none !important; right: auto; bottom: auto; margin: 1.5rem auto; width: min(520px, calc(100vw - 2rem)); }
    .motion-layer { transform: none !important; }
    .mist-layer { animation: none; }
  }
</style>

<script>
  // ── Scroll descent motion ──
  const descentStage = document.querySelector('.descent-stage') as HTMLElement | null;
  const descentCopies = [...document.querySelectorAll<HTMLElement>('.descent-copy')];

  function clamp(n: number, min = 0, max = 1) { return Math.min(max, Math.max(min, n)); }
  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
  function smoothstep(edge0: number, edge1: number, x: number) {
    const t = clamp((x - edge0) / (edge1 - edge0));
    return t * t * (3 - 2 * t);
  }
  function peak(start: number, mid: number, end: number, x: number) {
    if (x < start || x > end) return 0;
    if (x <= mid) return smoothstep(start, mid, x);
    return 1 - smoothstep(mid, end, x);
  }

  function updateDescent() {
    if (!descentStage) return;
    const rect = descentStage.getBoundingClientRect();
    const total = rect.height - window.innerHeight;
    const progress = clamp(-rect.top / total);

    const surfaceOut  = smoothstep(0.12, 0.42, progress);
    const deepIn      = smoothstep(0.55, 0.86, progress);
    const rootPeak    = peak(0.18, 0.52, 0.88, progress);
    const cutaway     = peak(0.12, 0.48, 0.78, progress);
    const mist        = 0.25 + peak(0.18, 0.52, 0.82, progress) * 0.5 + deepIn * 0.08;
    const signals     = smoothstep(0.35, 0.72, progress) * (1 - smoothstep(0.95, 1, progress));

    const r = document.documentElement;
    r.style.setProperty('--p',              progress.toFixed(4));
    r.style.setProperty('--surfaceOpacity', (1 - surfaceOut * 0.92).toFixed(3));
    r.style.setProperty('--cutawayOpacity', cutaway.toFixed(3));
    r.style.setProperty('--deepOpacity',    deepIn.toFixed(3));
    r.style.setProperty('--rootOpacity',    rootPeak.toFixed(3));
    r.style.setProperty('--signalOpacity',  signals.toFixed(3));
    r.style.setProperty('--mistOpacity',    mist.toFixed(3));
    r.style.setProperty('--surfaceY',       `${lerp(0,   -180,  progress).toFixed(1)}px`);
    r.style.setProperty('--cutawayY',       `${lerp(120, -140,  progress).toFixed(1)}px`);
    r.style.setProperty('--deepY',          `${lerp(160,    0,  deepIn).toFixed(1)}px`);
    r.style.setProperty('--leafY',          `${lerp(0,   -260,  progress).toFixed(1)}px`);
    r.style.setProperty('--rootY',          `${lerp(140, -120,  progress).toFixed(1)}px`);
    r.style.setProperty('--surfaceScale',   lerp(1,    1.12, progress).toFixed(3));
    r.style.setProperty('--cutawayScale',   lerp(1.06, 1.0,  cutaway).toFixed(3));
    r.style.setProperty('--deepScale',      lerp(1.12, 1.0,  deepIn).toFixed(3));

    const floor = progress < 0.34 ? 'surface' : progress < 0.70 ? 'root' : 'deep';
    descentCopies.forEach(el => el.classList.toggle('active', el.dataset.copy === floor));
  }

  let descentTicking = false;
  window.addEventListener('scroll', () => {
    if (!descentTicking) {
      requestAnimationFrame(() => { updateDescent(); descentTicking = false; });
      descentTicking = true;
    }
  }, { passive: true });
  window.addEventListener('resize', updateDescent);
  updateDescent();

  // ── Depth marker scroll tracking ──
  const depthSections = ['yasuragi', 'root-layer', 'deep-garden'];
  const depthLinks = Array.from(document.querySelectorAll('[data-depth]')) as HTMLAnchorElement[];

  function updateDepthMarker() {
    const midpoint = window.scrollY + window.innerHeight * 0.42;
    let active = depthSections[0];
    for (const id of depthSections) {
      const el = document.getElementById(id);
      if (el && el.offsetTop <= midpoint) active = id;
    }
    depthLinks.forEach(link => {
      link.classList.toggle('active', link.dataset.depth === active);
    });
  }

  window.addEventListener('scroll', updateDepthMarker, { passive: true });
  updateDepthMarker();

  // Seed packet live preview
  const fields = {
    ideaName: document.getElementById('ideaName') as HTMLInputElement,
    ideaSpark: document.getElementById('ideaSpark') as HTMLTextAreaElement,
    ideaBlock: document.getElementById('ideaBlock') as HTMLTextAreaElement,
    ideaNeed: document.getElementById('ideaNeed') as HTMLTextAreaElement,
    reviewTime: document.getElementById('reviewTime') as HTMLSelectElement,
  };

  const packetTitle = document.getElementById('packetTitle')!;
  const packetIdea = document.getElementById('packetIdea')!;
  const packetDate = document.getElementById('packetDate')!;
  const packetReview = document.getElementById('packetReview')!;

  function todayLabel() {
    return new Date().toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function updatePacket() {
    const idea = fields.ideaName.value.trim();
    packetTitle.textContent = idea || 'Seed of Potential';
    packetIdea.textContent = idea || "Your idea's name will appear here";
    packetDate.textContent = todayLabel();
    packetReview.textContent = fields.reviewTime.value || 'Later';
  }

  Object.values(fields).forEach(f => {
    f.addEventListener('input', updatePacket);
    f.addEventListener('change', updatePacket);
  });

  (document.getElementById('clearSeed') as HTMLButtonElement).addEventListener('click', () => {
    (document.getElementById('seedForm') as HTMLFormElement).reset();
    updatePacket();
  });

  (document.getElementById('downloadSeed') as HTMLButtonElement).addEventListener('click', () => {
    const now = new Date();
    const stamp = now.getFullYear().toString()
      + String(now.getMonth()+1).padStart(2,'0')
      + String(now.getDate()).padStart(2,'0')
      + '-'
      + String(now.getHours()).padStart(2,'0')
      + String(now.getMinutes()).padStart(2,'0');
    const accession = `GARDEN-${stamp}`;

    const packet = {
      type: 'LDI Seed Packet',
      accession,
      idea: fields.ideaName.value.trim() || 'Seed of Potential',
      spark: fields.ideaSpark.value.trim(),
      notReadyBecause: fields.ideaBlock.value.trim(),
      growthConditions: fields.ideaNeed.value.trim(),
      status: 'Dormant',
      planted: todayLabel(),
      review: fields.reviewTime.value,
      wardenNote: 'Let it rest.',
    };
    const blob = new Blob([JSON.stringify(packet, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'ldi-seed-packet.json';
    a.click();
    URL.revokeObjectURL(url);

    // Show confirmation state
    const confirmed = document.getElementById('plantingConfirmed') as HTMLElement;
    const accEl = document.getElementById('confirmAccession') as HTMLElement;
    const form = document.getElementById('seedForm') as HTMLFormElement;
    if (accEl) accEl.textContent = `ACC. ${accession}`;
    if (form) form.hidden = true;
    if (confirmed) confirmed.hidden = false;

    // Plant Another button — reset and show form again
    const plantAnother = document.getElementById('plantAnother');
    if (plantAnother) {
      plantAnother.addEventListener('click', () => {
        form.reset();
        updatePacket();
        form.hidden = false;
        confirmed.hidden = true;
      }, { once: true });
    }
  });

  updatePacket();
</script>
