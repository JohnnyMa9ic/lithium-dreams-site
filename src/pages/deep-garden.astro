  }
  .packet-data {
    display: grid;
    gap: 0;
  }
  .packet-row {
    border-top: 1px solid rgba(70,48,21,0.18);
    padding: 0.5rem 0;
  }
  .packet-row dt {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6c552e;
    margin-bottom: 0.15rem;
  }
  .packet-row dd {
    margin: 0;
    font-size: 0.9rem;
    color: var(--g-paper-ink);
  }
  .warden-stamp {
    text-align: center;
    font-family: var(--g-display);
    font-style: italic;
    font-size: 1rem;
    color: #594523;
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(70,48,21,0.18);
