  }

  /* ── Garden Footer ── */
  .garden-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 2rem clamp(1rem, 4vw, 3rem);
    border-top: 1px solid rgba(255,255,255,0.06);
    background: #040706;
    color: #9b927f;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .garden-footer strong { color: var(--g-amber); }
  .garden-footer em {
