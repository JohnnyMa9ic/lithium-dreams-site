---
import Layout from '../components/Layout.astro';
import TicketButton from '../components/TicketButton.astro';
---

<Layout title="Lithium Dreams Industries — The Last Roadside Attraction" activePage="/">
  <section class="front-gate">

    <!-- Full-bleed background: swap for AI-generated hero-front-gate.jpg when ready -->
    <div class="gate-bg" aria-hidden="true">
      <canvas id="rain-canvas"></canvas>
      <!-- Placeholder sign scene — replaced by hero image -->
      <div class="gate-sign-placeholder">
        <span class="sign-sub">The Last</span>
        <span class="sign-main">Roadside</span>
        <span class="sign-main">Attraction</span>
        <div class="sign-marquee">
          <span>Cryptids &middot; Arcade &middot; Gift Shop</span>
          <span>Weddings Tues &amp; Fri</span>
        </div>
      </div>
      <!-- Ambient right-side billboards (text only placeholders) -->
      <div class="billboard billboard--left" aria-hidden="true">
        <span>BIGFOOT</span>
        <span>NEXT EXIT →</span>
      </div>
      <div class="billboard billboard--right" aria-hidden="true">
        <span>SEE</span>
        <span>MOTHMAN</span>
        <span>museum</span>
      </div>
      <div class="gate-fog" aria-hidden="true"></div>
    </div>

    <!-- Sign hotspots — interactive areas over the hero image signs -->
    <div class="gate-hotspots" aria-label="Attraction signs">

      <!-- Main marquee: THE LAST ROADSIDE ATTRACTION -->
      <a href="/attraction" class="gate-hotspot gate-hotspot--main" aria-label="Enter the attraction">
        <span class="hotspot-tooltip">Enter the Attraction</span>
      </a>

      <!-- RAIN IS NORMAL. WONDER IS FREE. sandwich board (lower right) -->
      <a href="/museum" class="gate-hotspot gate-hotspot--board" aria-label="Museum">
        <span class="hotspot-tooltip">Museum</span>
      </a>

      <!-- LDI 1957 emblem (top center of image) -->
      <a href="/" class="gate-hotspot gate-hotspot--badge" aria-label="Lithium Dreams Industries home">
        <span class="hotspot-tooltip">LDI</span>
      </a>

    </div>

    <!-- Left overlay panel -->
    <div class="gate-panel">
      <div class="panel-brand">
        <p class="brand-name">Lithium Dreams<br/>Industries</p>
        <p class="brand-sub">The Last Roadside Attraction</p>
      </div>

      <ul class="panel-districts" aria-label="Districts">
        <li>Cryptids.</li>
        <li>Arcade.</li>
        <li>Gift Shop.</li>
        <li>Weddings Tuesdays &amp; Fridays.</li>
      </ul>

      <hr class="panel-rule" />

      <p class="panel-tagline">
        Words is welcome.<br/>
        Curiosity is required.<br/>
        Coffee is terrible.
      </p>

      <div class="panel-cta">
        <TicketButton href="/attraction" label="Enter the Attraction" />
      </div>

      <p class="panel-micro">Mind the puddles.</p>
    </div>

    <!-- Bottom status strip -->
    <div class="gate-statusbar" aria-hidden="true">
      <span>Maintenance has already been notified.</span>
      <span>Extraterrestrial parking has moved behind the chapel.</span>
      <span>Please remain on the path.</span>
    </div>

  </section>
</Layout>

<style>
  /* ─── Gate section fills viewport ─────────────────────────────── */
  .front-gate {
    position: relative;
    min-height: calc(100vh - 56px);
    overflow: hidden;
  }

  /* ─── Background scene ─────────────────────────────────────────── */
  .gate-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/hero-front-gate.jpg');
    background-size: cover;
    background-position: center top;
  }

  /* Rain canvas overlay */
  #rain-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    opacity: 0.7;
  }

  /* CSS placeholders — hero image provides the scene */
  .gate-sign-placeholder,
  .billboard,
  .billboard--left,
  .billboard--right {
    display: none;
  }

  /* Ground fog */
  .gate-fog {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(transparent, rgba(4, 7, 14, 0.85));
    z-index: 2;
    pointer-events: none;
  }

  /* ─── Sign hotspots ─────────────────────────────────────────────── */
  .gate-hotspots {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none; /* container doesn't block clicks */
  }

  .gate-hotspot {
    position: absolute;
    pointer-events: all;
    text-decoration: none;
    border-radius: 3px;
    border: 1px solid transparent;
    transition: background 0.2s ease, border-color 0.2s ease;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 6%;
  }

  .gate-hotspot:hover {
    background: radial-gradient(ellipse at 50% 40%, rgba(232, 164, 32, 0.13) 0%, transparent 70%);
    border-color: rgba(232, 164, 32, 0.22);
  }

  /* Main marquee — THE LAST ROADSIDE ATTRACTION */
  .gate-hotspot--main {
    left: 33%;
    top: 8%;
    width: 56%;
    height: 57%;
  }

  /* RAIN IS NORMAL. WONDER IS FREE. board — lower right */
  .gate-hotspot--board {
    left: 71%;
    top: 55%;
    width: 18%;
    height: 27%;
  }

  /* LDI 1957 badge — top center */
  .gate-hotspot--badge {
    left: 43%;
    top: 3%;
    width: 13%;
    height: 16%;
  }

  /* Tooltip label — appears on hover */
  .hotspot-tooltip {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: transparent;
    background: rgba(4, 7, 14, 0.75);
    padding: 2px 8px;
    border-radius: 1px;
    white-space: nowrap;
    transition: color 0.2s ease;
    pointer-events: none;
  }

  .gate-hotspot:hover .hotspot-tooltip {
    color: var(--neon-amber);
  }

  /* On mobile the image is shorter — hide hotspots (panel covers lower half anyway) */
  @media (max-width: 768px) {
    .gate-hotspots { display: none; }
  }

  /* ─── Left panel ─────────────────────────────────────────────────── */
  .gate-panel {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100vh - 56px - 40px);
    width: min(380px, 38vw);
    padding: var(--space-xl) var(--space-xl) var(--space-lg);
    background: linear-gradient(
      to right,
      rgba(4, 7, 14, 0.96) 0%,
      rgba(4, 7, 14, 0.88) 70%,
      rgba(4, 7, 14, 0.0) 100%
    );
    gap: var(--space-lg);
  }

  .panel-brand {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    color: var(--paper);
    line-height: 0.95;
    letter-spacing: 0.04em;
  }

  .brand-sub {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--neon-amber);
    text-transform: uppercase;
  }

  .panel-districts {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .panel-districts li {
    font-family: var(--font-sub);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: rgba(232, 222, 200, 0.45);
    text-transform: uppercase;
  }

  .panel-rule {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin: 0;
  }

  .panel-tagline {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(232, 222, 200, 0.7);
    line-height: 1.7;
  }

  .panel-cta {
    display: flex;
  }

  .panel-micro {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(232, 222, 200, 0.25);
    letter-spacing: 0.1em;
    margin-top: calc(-1 * var(--space-sm));
  }

  /* ─── Status bar ─────────────────────────────────────────────────── */
  .gate-statusbar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-lg);
    background: rgba(4, 7, 14, 0.85);
    border-top: var(--border-faint);
    overflow: hidden;
  }

  .gate-statusbar span {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: rgba(232, 222, 200, 0.25);
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* ─── Responsive ─────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .gate-panel {
      width: 100%;
      background: linear-gradient(
        to bottom,
        rgba(4, 7, 14, 0.0) 0%,
        rgba(4, 7, 14, 0.97) 40%,
        rgba(4, 7, 14, 1) 100%
      );
      justify-content: flex-end;
      padding: var(--space-lg);
      min-height: 0;
    }

    .front-gate {
      display: flex;
      flex-direction: column;
    }

    .gate-bg {
      position: relative;
      height: 60vw;
      min-height: 280px;
    }

    .gate-sign-placeholder {
      top: 45%;
      left: 50%;
    }

    .billboard { display: none; }
    .gate-statusbar span:not(:first-child) { display: none; }
  }

  @media (max-width: 480px) {
    .brand-name { font-size: 2rem; }
  }
</style>

<script>
  const canvas = document.getElementById('rain-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    const drops = Array.from({ length: 160 }, () => ({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      len: 8 + Math.random() * 20,
      speed: 5 + Math.random() * 9,
      opacity: 0.12 + Math.random() * 0.38,
    }));

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      drops.forEach(d => {
        ctx.beginPath();
        ctx.moveTo(d.x, d.y);
        ctx.lineTo(d.x - d.len * 0.1, d.y + d.len);
        ctx.strokeStyle = `rgba(100, 140, 200, ${d.opacity})`;
        ctx.lineWidth = 0.7;
        ctx.stroke();
        d.y += d.speed;
        d.x -= d.speed * 0.08;
        if (d.y > canvas.height || d.x < 0) {
          d.y = -d.len;
          d.x = Math.random() * canvas.width;
        }
      });
      requestAnimationFrame(draw);
    }
    draw();
  }
</script>
