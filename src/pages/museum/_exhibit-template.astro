---
// museum-exhibit.astro — LDI Museum Exhibit Template
// Generated by episode-to-museum skill. Fields below are populated per-episode.
// Accession: MUS-###  |  Episode: BCT-###

import Layout from '../../components/Layout.astro';
import MuseumPlaque from '../../components/MuseumPlaque.astro';
import MaintenanceTag from '../../components/MaintenanceTag.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CRTFrame from '../../components/CRTFrame.astro';

// ── EXHIBIT METADATA ── populated by episode-to-museum skill ──────────────────
const exhibit = {
  accession: 'MUS-006',
  episode_id: 'BCT-001',
  episode_title: 'Episode Title Here',
  episode_url: '/broadcasts/#BCT-001',
  title: 'Exhibit Title',
  subtitle: 'One-line deadpan description. Factual. Slightly strange.',
  classification: 'Cryptid · Classification Here',
  first_documented: 'Month DD, YYYY',
  location: 'City, State / Region',
  threat_assessment: '[REDACTED]',
  status: 'ACTIVE · OPEN FOR VIEWING',
  // Optional: set to path string if narration audio was generated
  narration_audio: null as string | null,
};
// ── END METADATA ──────────────────────────────────────────────────────────────
---

<Layout title={`${exhibit.title} — Museum — Lithium Dreams Industries`} activePage="/museum">
  <div class="page-hero exhibit-hero">
    <div class="page-hero-fade"></div>
    <div class="exhibit-hero-label mono" aria-hidden="true">
      {exhibit.accession}
    </div>
  </div>

  <div class="district-page">
    <div class="district-header">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Midway', href: '/attraction' },
        { label: 'Museum', href: '/museum' },
        { label: exhibit.accession },
      ]} />
      <MaintenanceTag status="ACTIVE" size="md" />
    </div>

    <MuseumPlaque
      accession={exhibit.accession}
      title={exhibit.title}
      subtitle={exhibit.subtitle}
    />

    <!-- CLASSIFICATION PLACARD -->
    <CRTFrame label="SPECIMEN DATA">
      <div class="placard-grid">
        <div class="placard-row">
          <span class="placard-key mono">ACCESSION</span>
          <span class="placard-val mono">{exhibit.accession}</span>
        </div>
        <div class="placard-row">
          <span class="placard-key mono">STATUS</span>
          <span class="placard-val mono placard-val--active">{exhibit.status}</span>
        </div>
        <div class="placard-row">
          <span class="placard-key mono">CLASSIFICATION</span>
          <span class="placard-val mono">{exhibit.classification}</span>
        </div>
        <div class="placard-row">
          <span class="placard-key mono">FIRST DOCUMENTED</span>
          <span class="placard-val mono">{exhibit.first_documented}</span>
        </div>
        <div class="placard-row">
          <span class="placard-key mono">LOCATION</span>
          <span class="placard-val mono">{exhibit.location}</span>
        </div>
        <div class="placard-row">
          <span class="placard-key mono">THREAT ASSESSMENT</span>
          <span class="placard-val mono placard-val--redacted">{exhibit.threat_assessment}</span>
        </div>
      </div>
    </CRTFrame>

    <!-- OPTIONAL NARRATION AUDIO -->
    {exhibit.narration_audio && (
      <div class="narration-block">
        <p class="section-eyebrow mono">Audio Dossier</p>
        <div class="narration-player">
          <p class="mono text-dim">// field narration · archival recording</p>
          <audio controls class="exhibit-audio">
            <source src={exhibit.narration_audio} type="audio/mpeg" />
            Your browser does not support audio playback.
          </audio>
        </div>
      </div>
    )}

    <!-- EXHIBIT BODY — populated by Bob synthesis -->
    <div class="exhibit-body">
      <p class="section-eyebrow mono">Field Notes</p>
      <div class="exhibit-divider mono" aria-hidden="true">────────────────────────────────────────</div>

      {/*
        ── BOB SYNTHESIS OUTPUT GOES HERE ──────────────────────────────────────
        Replace this comment block with the synthesized exhibit body.
        Target: 400–600 words. LDI dossier voice. Deadpan, factual, slightly strange.
        Structure:
          1. Phenomenon overview / what it is
          2. Key sighting or event data (dates, witnesses, specifics)
          3. The anomaly — what doesn't add up
          4. Connection to the episode research
        End with the broadcast cross-reference line (see below).
        No fabrication. Use [REDACTED] or [DATA PENDING] for gaps.
        ────────────────────────────────────────────────────────────────────────
      */}

      <div class="exhibit-text">
        <p class="exhibit-placeholder mono text-dim">
          // Exhibit body pending synthesis. Run episode-to-museum to populate.
        </p>
      </div>

      <div class="exhibit-divider mono" aria-hidden="true">────────────────────────────────────────</div>
    </div>

    <!-- BROADCAST CROSS-REFERENCE -->
    <CRTFrame label="SOURCE TRANSMISSION">
      <div class="broadcast-ref">
        <p class="mono text-dim">// This exhibit was assembled from research conducted during:</p>
        <a href={exhibit.episode_url} class="broadcast-link mono">
          → BROADCAST: {exhibit.episode_title} — {exhibit.episode_id}
        </a>
        <p class="mono text-dim">// The research lives here after the broadcast ends.</p>
      </div>
    </CRTFrame>

    <!-- MUSEUM NAV -->
    <div class="exhibit-nav">
      <a href="/museum" class="exhibit-nav-link mono">← Return to Museum Index</a>
    </div>

  </div>
</Layout>

<style>
  /* Hero */
  .exhibit-hero {
    width: 100%;
    min-height: 45vh;
    background: radial-gradient(ellipse at 30% 60%, #12080a 0%, #080508 50%, #000 100%);
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    overflow: hidden;
  }

  .exhibit-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(255,255,255,0.015) 2px,
        rgba(255,255,255,0.015) 4px
      );
    pointer-events: none;
  }

  .exhibit-hero-label {
    position: absolute;
    bottom: 4rem;
    left: var(--content-pad, 1.5rem);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: rgba(255, 160, 0, 0.35);
    z-index: 1;
  }

  .page-hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent, var(--ldi-bg, #050505));
    z-index: 1;
  }

  /* Placard */
  .placard-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .placard-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  @media (max-width: 600px) {
    .placard-row {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }

  .placard-key {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.35);
  }

  .placard-val {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--ldi-text, #d4cfc8);
  }

  .placard-val--active {
    color: var(--ldi-teal, #00e5cc);
  }

  .placard-val--redacted {
    color: rgba(255,255,255,0.25);
    font-style: italic;
  }

  /* Narration */
  .narration-block {
    margin: 0;
  }

  .narration-player {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .exhibit-audio {
    width: 100%;
    filter: invert(1) hue-rotate(180deg) brightness(0.7);
  }

  /* Exhibit body */
  .exhibit-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .exhibit-divider {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.12);
    letter-spacing: 0;
    overflow: hidden;
  }

  .exhibit-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0.5rem 0;
  }

  .exhibit-text p {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--ldi-text, #d4cfc8);
  }

  .exhibit-placeholder {
    font-size: 0.75rem !important;
    letter-spacing: 0.05em;
    opacity: 0.5;
  }

  /* Broadcast ref */
  .broadcast-ref {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .broadcast-link {
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: var(--ldi-amber, #ffa000);
    text-decoration: none;
    transition: color 0.2s;
  }

  .broadcast-link:hover {
    color: #fff;
  }

  /* Nav */
  .exhibit-nav {
    padding-top: 1rem;
  }

  .exhibit-nav-link {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.2s;
  }

  .exhibit-nav-link:hover {
    color: var(--ldi-text, #d4cfc8);
  }

  /* Velvet rope */
  .velvet-rope-notice {
    text-align: center;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    margin: 0.75rem 0 1.5rem;
  }
</style>
