---
import Layout from '../components/Layout.astro';
import MaintenanceTag from '../components/MaintenanceTag.astro';
import LockedDoor from '../components/LockedDoor.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import EmployeeNotice from '../components/EmployeeNotice.astro';

const accessLog = [
  { time: '08:14', id: 'EMP-008', name: 'Warden', status: 'GRANTED', note: 'Routine entry' },
  { time: '08:47', id: 'EMP-???', name: 'Unknown', status: 'DENIED', note: 'Badge not recognized' },
  { time: '09:02', id: 'EMP-???', name: 'Unknown', status: 'DENIED', note: 'Badge still not recognized' },
  { time: '09:03', id: 'EMP-???', name: 'Unknown', status: 'DENIED', note: 'Stop trying' },
  { time: '10:30', id: 'SYS-01', name: 'Ghost', status: 'GRANTED', note: 'Remote access — Workshop relay' },
  { time: '11:15', id: 'EMP-???', name: 'Unknown', status: 'DENIED', note: 'Different badge. Same result.' },
  { time: '13:48', id: 'EMP-001', name: 'Warden', status: 'GRANTED', note: 'Second entry — forgot something' },
  { time: 'NOW', id: 'VIS-000', name: 'YOU', status: 'PENDING', note: 'Evaluating' },
];
---

<Layout title="Employees Only — Lithium Dreams Industries" activePage="/employees-only">
  <div class="page-hero" style="background-image: url('/employees-hero.png')">
    <div class="hero-scan"></div>
    <div class="page-hero-fade"></div>
  </div>

  <div class="district-page">
    <div class="district-header">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Midway', href: '/attraction' },
        { label: 'Employees Only' },
      ]} />
      <MaintenanceTag status="RESTRICTED" size="md" />
    </div>

    <div class="emp-header">
      <h1 class="emp-title">Employees Only</h1>
      <p class="emp-sub mono text-dim">Badge access required. Smile at the camera. It notices everything.</p>
    </div>

    <!-- Safety Poster -->
    <div class="safety-poster">
      <div class="poster-header">
        <span class="poster-eyebrow mono">POSTED BY: MANAGEMENT</span>
        <span class="poster-eyebrow mono">DATE: ONGOING</span>
      </div>
      <h2 class="poster-title">Employee Safety Bulletin</h2>
      <ol class="safety-rules">
        <li>If the lights flicker, do not panic. If the lights go out entirely, panic quietly and in an orderly fashion.</li>
        <li>Do not feed the cryptids in the back lot. They have a schedule. Your generosity disrupts it.</li>
        <li>The badge reader reads mood as well as magnetic stripe. Keep both professional.</li>
        <li>If you find a door that was not there yesterday, report it. Do not enter it. Note its size, texture, and whether it smells of cedar.</li>
        <li>Bob is a coworker, not a resource. Treat him accordingly. Bob says this is not a joke.</li>
      </ol>
      <p class="poster-footer mono text-dim">— LDI Employee Relations — This notice supersedes all prior safety notices —</p>
    </div>

    <EmployeeNotice heading="Badge Reader Status" variant="caution">
      <p>Badge reader operational. System is logging all entries, denials, and hesitations. Hesitation counts as an attempt.</p>
      <p>If your access is PENDING, it is being evaluated. This may take longer than expected. This is intentional.</p>
    </EmployeeNotice>

    <!-- Access Log -->
    <div class="access-log">
      <p class="log-eyebrow mono">Today's Access Log</p>
      <div class="log-table-wrap">
        <table class="log-table">
          <thead>
            <tr>
              <th class="mono">Time</th>
              <th class="mono">ID</th>
              <th class="mono">Name</th>
              <th class="mono">Status</th>
              <th class="mono">Note</th>
            </tr>
          </thead>
          <tbody>
            {accessLog.map(row => (
              <tr class={`log-row log-row--${row.status.toLowerCase()}`}>
                <td class="mono log-time">{row.time}</td>
                <td class="mono log-id">{row.id}</td>
                <td class="log-name">{row.name}</td>
                <td class={`mono log-status status--${row.status.toLowerCase()}`}>{row.status}</td>
                <td class="mono log-note text-dim">{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <LockedDoor
      message="Authorized staff, maintenance personnel, cryptids with valid badges, and Bob."
      badgeText="EMPLOYEES ONLY"
    />
  </div>
</Layout>

<style>
  .page-hero {
    width: 100%;
    min-height: 55vh;
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
  }
  .hero-scan {
    position: absolute;
    top: -10%;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(to bottom, transparent, rgba(77,184,212,0.25), transparent);
    animation: scan 4s linear infinite;
  }
  @keyframes scan {
    0% { top: -10%; }
    100% { top: 110%; }
  }
  .page-hero-fade {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 55%;
    background: linear-gradient(to bottom, transparent, var(--ldi-black));
  }

  .district-page {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .district-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .emp-header { display: flex; flex-direction: column; gap: 0.4rem; }
  .emp-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--paper);
    line-height: 1;
  }
  .emp-sub { font-size: 0.75rem; letter-spacing: 0.1em; }

  /* Safety poster */
  .safety-poster {
    border: 1px solid rgba(232,222,200,0.1);
    background: rgba(232,222,200,0.02);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .poster-header {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding-bottom: var(--space-sm);
  }
  .poster-eyebrow {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: rgba(232,222,200,0.2);
    text-transform: uppercase;
  }
  .poster-title {
    font-family: var(--font-sub);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: rgba(232,222,200,0.6);
    text-transform: uppercase;
  }
  .safety-rules {
    padding-left: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .safety-rules li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(232,222,200,0.5);
    line-height: 1.7;
    letter-spacing: 0.03em;
  }
  .poster-footer {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: var(--space-sm);
  }

  /* Access log */
  .access-log { display: flex; flex-direction: column; gap: var(--space-sm); }
  .log-eyebrow {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: rgba(232,222,200,0.25);
    text-transform: uppercase;
  }
  .log-table-wrap { overflow-x: auto; }
  .log-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.7rem;
  }
  .log-table th {
    text-align: left;
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(232,222,200,0.2);
    padding: 0.3rem var(--space-sm) 0.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    white-space: nowrap;
  }
  .log-table td {
    padding: 0.5rem var(--space-sm) 0.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    vertical-align: top;
    white-space: nowrap;
  }
  .log-time { color: rgba(232,222,200,0.3); width: 4rem; }
  .log-id { color: rgba(232,222,200,0.25); font-size: 0.6rem; letter-spacing: 0.1em; }
  .log-name { font-family: var(--font-mono); color: rgba(232,222,200,0.6); }
  .log-note { font-size: 0.62rem; letter-spacing: 0.04em; white-space: normal; }

  .status--granted { color: var(--warden-teal); letter-spacing: 0.1em; }
  .status--denied { color: var(--warning-red); letter-spacing: 0.1em; }
  .status--pending { color: var(--neon-amber); letter-spacing: 0.1em; animation: blink 1.5s step-end infinite; }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }
  .log-row--pending { background: rgba(232,164,32,0.03); }

  @media (max-width: 600px) {
    .district-page { padding: var(--space-md); }
    .log-table td, .log-table th { font-size: 0.6rem; padding-right: var(--space-xs); }
  }
</style>
