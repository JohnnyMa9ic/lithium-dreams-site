---
import Layout from '../components/Layout.astro';
import LockedDoor from '../components/LockedDoor.astro';
import MaintenanceTag from '../components/MaintenanceTag.astro';
---

<Layout title="Employees Only — Lithium Dreams Industries" activePage="/employees-only">
  <div class="district-page">
    <div class="district-header">
      <a href="/attraction" class="back-link mono">← Back to Midway</a>
      <MaintenanceTag status="RESTRICTED" size="md" />
    </div>

    <LockedDoor
      message="Authorized staff, maintenance personnel, cryptids with valid badges, and Bob."
      badgeText="EMPLOYEES ONLY"
    />
  </div>
</Layout>

<style>
  .district-page {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .district-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .back-link {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(232, 222, 200, 0.4);
  }
  .back-link:hover { color: var(--paper); }
</style>
