---
import Layout from '../components/Layout.astro';
import DistrictCard from '../components/DistrictCard.astro';
import { districts } from '../data/districts';

const midwayDistricts = districts;
---

<Layout title="Main Midway — Lithium Dreams Industries" activePage="/attraction">

  <!-- Panoramic Midway scene — each sign is a hotspot link -->
  <section class="midway-panorama" aria-label="Midway district map">
    <div class="panorama-wrap">
      <img
        src="/images/midway-panorama.jpg"
        alt="The Midway — a rain-slicked courtyard at night surrounded by neon signs for each district"
        class="panorama-img"
        width="1200"
        height="630"
      />

      <!-- Hotspot links over each sign, percentage-positioned -->
      <!-- GIFT SHOP — left panel -->
      <a href="/gift-shop" class="hotspot" style="left:2.5%; top:8%; width:16%; height:65%;" aria-label="Gift Shop">
        <span class="hotspot-label">Gift Shop</span>
      </a>

      <!-- BOB'S FORTUNE EMPORIUM -->
      <a href="/fortune" class="hotspot" style="left:20%; top:8%; width:15%; height:58%;" aria-label="Bob's Fortune Emporium">
        <span class="hotspot-label">Fortune Emporium</span>
      </a>

      <!-- ARCADE — center marquee -->
      <a href="/arcade" class="hotspot" style="left:36%; top:3%; width:22%; height:65%;" aria-label="Arcade">
        <span class="hotspot-label">Arcade</span>
      </a>

      <!-- MUSEUM -->
      <a href="/museum" class="hotspot" style="left:59%; top:8%; width:14%; height:58%;" aria-label="Museum">
        <span class="hotspot-label">Museum</span>
      </a>

      <!-- SNACK COUNTER -->
      <a href="#" class="hotspot hotspot--locked" style="left:72%; top:5%; width:14%; height:52%;" aria-label="Snack Counter — coming soon">
        <span class="hotspot-label">Snack Counter</span>
      </a>

      <!-- LDI 1957 badge — top right -->
      <a href="/" class="hotspot" style="right:1%; top:2%; width:8%; height:20%;" aria-label="LDI — Home">
        <span class="hotspot-label">Home</span>
      </a>

      <!-- LOST & LOST & FOUND — lower left -->
      <a href="#" class="hotspot hotspot--locked" style="left:1.5%; top:60%; width:14%; height:32%;" aria-label="Lost & Found — coming soon">
        <span class="hotspot-label">Lost &amp; Found</span>
      </a>

      <!-- WEDDING CHAPEL — lower center-right -->
      <a href="/chapel" class="hotspot" style="left:57%; top:58%; width:16%; height:36%;" aria-label="Wedding Chapel">
        <span class="hotspot-label">Wedding Chapel</span>
      </a>

      <!-- EMPLOYEES ONLY — far right — leads to Ghost's Workshop (command center) -->
      <a href="/workshop" class="hotspot" style="left:77%; top:38%; width:13%; height:42%;" aria-label="Employees Only — Ghost's Workshop">
        <span class="hotspot-label">Employees Only</span>
      </a>

      <!-- YOU ARE HERE floor mosaic — cosmetic, no link -->
      <div class="you-are-here" aria-hidden="true">YOU ARE HERE</div>
    </div>

    <div class="panorama-fade" aria-hidden="true"></div>
  </section>

  <!-- Intercom ticker -->
  <div class="intercom-ticker" aria-label="Midway announcements">
    <span class="ticker-label mono">INTERCOM</span>
    <div class="ticker-track-wrap">
      <div class="ticker-track">
        <span class="ticker-msg mono">Welcome to the Midway. Please keep your hands inside the lore. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; Bob's Fortune Emporium is operational. Results not guaranteed. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; The Museum of Ongoing Events is accepting new submissions. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; Wedding Chapel: open Tuesdays and Fridays. Do not ask about the back room. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; The Arcade cabinet in the corner is still technically running. We are aware. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; Lost &amp; Found hours: whenever someone remembers to open it. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; The Warden would like to remind everyone that the cryptids are not decorative. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp;</span>
        <span class="ticker-msg mono" aria-hidden="true">Welcome to the Midway. Please keep your hands inside the lore. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; Bob's Fortune Emporium is operational. Results not guaranteed. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; The Museum of Ongoing Events is accepting new submissions. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; Wedding Chapel: open Tuesdays and Fridays. Do not ask about the back room. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; The Arcade cabinet in the corner is still technically running. We are aware. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; Lost &amp; Found hours: whenever someone remembers to open it. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp; The Warden would like to remind everyone that the cryptids are not decorative. &nbsp;&nbsp;&nbsp;&bull;&nbsp;&nbsp;&nbsp;</span>
      </div>
    </div>
  </div>

  <!-- Status panel + ticket card -->
  <section class="midway-status-section">
    <div class="status-panel">
      <p class="status-panel-eyebrow mono">District Status</p>
      <div class="status-list">
        <div class="status-item"><span class="sdot sdot--active"></span><span class="mono sname">Gift Shop</span></div>
        <div class="status-item"><span class="sdot sdot--active"></span><span class="mono sname">Fortune Emporium</span></div>
        <div class="status-item"><span class="sdot sdot--flickering"></span><span class="mono sname">Arcade</span></div>
        <div class="status-item"><span class="sdot sdot--active"></span><span class="mono sname">Museum</span></div>
        <div class="status-item"><span class="sdot sdot--active"></span><span class="mono sname">Wedding Chapel</span></div>
        <div class="status-item"><span class="sdot sdot--active"></span><span class="mono sname">Garden</span></div>
        <div class="status-item"><span class="sdot sdot--restricted"></span><span class="mono sname">Employees Only</span></div>
        <div class="status-item"><span class="sdot sdot--offline"></span><span class="mono sname">Snack Counter</span><span class="mono sname-note text-dim">soon</span></div>
      </div>
    </div>
    <div class="ticket-card">
      <div class="ticket-top">
        <span class="ticket-kicker mono">General Admission</span>
        <span class="ticket-price">$12</span>
      </div>
      <p class="ticket-copy">Access to all open Midway districts. Cryptid encounters not included but also not excluded.</p>
      <div class="ticket-details mono text-dim">
        <span>Valid: one entry</span>
        <span>Non-refundable after threshold</span>
      </div>
      <div class="ticket-tear"></div>
      <div class="ticket-stub">
        <span class="mono stub-label">KEEP THIS PORTION</span>
        <span class="mono stub-text text-dim">LDI ADMIT ONE</span>
      </div>
    </div>
  </section>

  <!-- District grid -->
  <section class="midway-grid-section">
    <p class="midway-eyebrow mono">District Directory</p>
    <div class="midway-grid">
      {midwayDistricts.map(district => (
        <DistrictCard district={district} />
      ))}
    </div>
    <p class="midway-footer mono text-dim">
      Additional districts are indicated by the arrows. The arrows are correct. Probably.
    </p>
  </section>

  <!-- Lore log -->
  <section class="lore-log-section">
    <p class="lore-eyebrow mono">Incident Log</p>
    <div class="lore-entries">
      <div class="lore-entry">
        <span class="lore-time mono text-dim">Year 3 — Tuesday</span>
        <p class="lore-body mono">The organ in the wedding chapel played something no one requested. Guests appreciated it. Warden says this was not unexpected.</p>
      </div>
      <div class="lore-entry">
        <span class="lore-time mono text-dim">Year 6 — Friday</span>
        <p class="lore-body mono">A visitor left a note in the Lost &amp; Found. The note was addressed to the Midway. The Midway has been informed.</p>
      </div>
      <div class="lore-entry">
        <span class="lore-time mono text-dim">Year 7 — Unknown</span>
        <p class="lore-body mono">The Crossroads Incident. Museum is documenting. Details pending clearance.</p>
      </div>
      <div class="lore-entry">
        <span class="lore-time mono text-dim">Present — Ongoing</span>
        <p class="lore-body mono">You are here. The Midway has noted your arrival. Welcome. Please don't rush.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Panorama section ── */
  .midway-panorama {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .panorama-wrap {
    position: relative;
    width: 100%;
  }

  .panorama-img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 70vh;
    object-fit: cover;
    object-position: center top;
  }

  /* Hotspot transparent overlay links */
  .hotspot {
    position: absolute;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 4%;
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 2px;
    transition: background 0.15s, border-color 0.15s;
    cursor: pointer;
  }

  .hotspot:hover {
    background: rgba(232, 164, 32, 0.08);
    border-color: rgba(232, 164, 32, 0.35);
  }

  .hotspot--locked:hover {
    background: rgba(44, 48, 56, 0.2);
    border-color: rgba(232, 222, 200, 0.15);
    cursor: not-allowed;
  }

  .hotspot-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(232, 164, 32, 0);  /* invisible by default */
    background: rgba(4, 7, 14, 0.7);
    padding: 2px 6px;
    border-radius: 1px;
    white-space: nowrap;
    transition: color 0.15s;
    pointer-events: none;
  }

  .hotspot:hover .hotspot-label {
    color: var(--neon-amber);
  }

  .hotspot--locked:hover .hotspot-label {
    color: rgba(232, 222, 200, 0.4);
  }

  /* YOU ARE HERE floor text */
  .you-are-here {
    position: absolute;
    bottom: 12%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: clamp(0.5rem, 1vw, 0.75rem);
    letter-spacing: 0.4em;
    color: rgba(232, 164, 32, 0.25);
    pointer-events: none;
    white-space: nowrap;
  }

  /* Gradient fade into page background */
  .panorama-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 35%;
    background: linear-gradient(transparent, var(--ldi-black));
    pointer-events: none;
  }

  /* ── Grid section ── */
  .midway-grid-section {
    padding: var(--space-xl);
    padding-top: var(--space-lg);
    max-width: 1100px;
    margin: 0 auto;
  }

  .midway-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--neon-amber);
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .midway-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .midway-footer {
    font-size: 0.7rem;
    text-align: center;
  }

  /* ── Intercom ticker ── */
  .intercom-ticker {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: rgba(232,164,32,0.04);
    border-top: 1px solid rgba(232,164,32,0.12);
    border-bottom: 1px solid rgba(232,164,32,0.12);
    overflow: hidden;
    padding: 0.5rem 0;
  }
  .ticker-label {
    flex-shrink: 0;
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    color: var(--neon-amber);
    text-transform: uppercase;
    padding: 0 var(--space-md);
    border-right: 1px solid rgba(232,164,32,0.2);
    white-space: nowrap;
  }
  .ticker-track-wrap { overflow: hidden; flex: 1; }
  .ticker-track {
    display: flex;
    width: max-content;
    animation: ticker 60s linear infinite;
  }
  .ticker-msg {
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: rgba(232,222,200,0.45);
    white-space: nowrap;
    padding-right: 0;
  }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Status + ticket section ── */
  .midway-status-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    padding: var(--space-xl);
    max-width: 1100px;
    margin: 0 auto;
  }

  .status-panel { display: flex; flex-direction: column; gap: var(--space-sm); }
  .status-panel-eyebrow {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: rgba(232,222,200,0.25);
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .status-list { display: flex; flex-direction: column; gap: 0.4rem; }
  .status-item { display: flex; align-items: center; gap: var(--space-sm); }
  .sdot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .sdot--active { background: var(--warden-teal); }
  .sdot--flickering { background: var(--neon-amber); animation: flick 1.8s infinite; }
  .sdot--restricted { background: rgba(194,59,34,0.6); }
  .sdot--offline { background: rgba(255,255,255,0.12); }
  @keyframes flick { 0%,100%{opacity:1} 50%{opacity:0.2} }
  .sname { font-size: 0.68rem; letter-spacing: 0.08em; color: rgba(232,222,200,0.5); }
  .sname-note { font-size: 0.55rem; letter-spacing: 0.12em; margin-left: 0.25rem; }

  /* Ticket card */
  .ticket-card {
    border: 1px solid rgba(232,164,32,0.2);
    display: flex;
    flex-direction: column;
    background: rgba(232,164,32,0.03);
  }
  .ticket-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-md) var(--space-md) var(--space-sm);
  }
  .ticket-kicker {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: rgba(232,222,200,0.3);
    text-transform: uppercase;
  }
  .ticket-price {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--neon-amber);
    line-height: 1;
  }
  .ticket-copy {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: rgba(232,222,200,0.5);
    line-height: 1.6;
    letter-spacing: 0.03em;
    padding: 0 var(--space-md) var(--space-sm);
  }
  .ticket-details {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0 var(--space-md) var(--space-md);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
  }
  .ticket-tear {
    height: 1px;
    background-image: repeating-linear-gradient(
      90deg,
      rgba(232,164,32,0.3) 0,
      rgba(232,164,32,0.3) 4px,
      transparent 4px,
      transparent 10px
    );
    margin: 0 var(--space-md);
  }
  .ticket-stub {
    display: flex;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
    border-top: none;
  }
  .stub-label { font-size: 0.55rem; letter-spacing: 0.2em; color: rgba(232,164,32,0.4); text-transform: uppercase; }
  .stub-text { font-size: 0.6rem; letter-spacing: 0.15em; }

  /* ── Lore log ── */
  .lore-log-section {
    padding: var(--space-xl);
    padding-top: 0;
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .lore-eyebrow {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: rgba(232,222,200,0.2);
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }
  .lore-entries { display: flex; flex-direction: column; gap: 0; }
  .lore-entry {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    align-items: baseline;
  }
  .lore-entry:last-child { border-bottom: none; }
  .lore-time { font-size: 0.6rem; letter-spacing: 0.1em; }
  .lore-body { font-size: 0.68rem; color: rgba(232,222,200,0.4); line-height: 1.6; letter-spacing: 0.03em; }

  @media (max-width: 700px) {
    .midway-status-section { grid-template-columns: 1fr; }
    .lore-entry { grid-template-columns: 1fr; gap: 0.2rem; }
  }
  @media (max-width: 600px) {
    .midway-grid-section { padding: var(--space-md); }
    .midway-grid { grid-template-columns: 1fr; }
    .midway-status-section { padding: var(--space-md); }
    .lore-log-section { padding: var(--space-md); }
    .hotspot-label { color: rgba(232, 164, 32, 0.4); }
  }
</style>
