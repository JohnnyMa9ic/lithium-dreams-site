---
interface Props {
  href: string;
  label?: string;
  arrow?: boolean;
  variant?: 'primary' | 'ghost';
}
const { href, label = 'Enter', arrow = true, variant = 'primary' } = Astro.props;
---

<a href={href} class:list={['ticket-btn', `ticket-btn--${variant}`]}>
  {label}{arrow && <span class="ticket-arrow"> &rarr;</span>}
</a>

<style>
  .ticket-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    font-family: var(--font-sub);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--neon-amber);
    color: var(--neon-amber);
    background: transparent;
    transition: background var(--transition-fast), color var(--transition-fast);
    position: relative;
  }

  .ticket-btn::before,
  .ticket-btn::after {
    content: '';
    position: absolute;
    left: -6px;
    right: -6px;
    height: 2px;
    background: repeating-linear-gradient(
      to right,
      var(--neon-amber) 0px,
      var(--neon-amber) 4px,
      transparent 4px,
      transparent 8px
    );
  }
  .ticket-btn::before { top: -4px; }
  .ticket-btn::after  { bottom: -4px; }

  .ticket-btn:hover {
    background: var(--neon-amber);
    color: var(--ldi-black);
  }

  .ticket-btn--ghost {
    border-color: rgba(232, 164, 32, 0.4);
    color: rgba(232, 164, 32, 0.7);
  }
  .ticket-btn--ghost:hover {
    border-color: var(--neon-amber);
    color: var(--neon-amber);
    background: transparent;
  }

  .ticket-arrow {
    font-family: sans-serif;
  }
</style>
