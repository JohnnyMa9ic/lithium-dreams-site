---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  rainOnHero?: boolean;
  activePage?: string;
}

const {
  title = 'Lithium Dreams Industries',
  description = 'The Last Roadside Attraction at the Edge of the Universe. Cryptids. Arcade. Gift Shop. Weddings Tuesdays & Fridays.',
  ogImage = '/studio-hero.png',
  activePage = '',
} = Astro.props;

const siteURL = 'https://lithium-dreams.com';
const canonicalURL = new URL(Astro.url.pathname, siteURL);

const navLinks = [
  { href: '/attraction', label: 'Attraction' },
  { href: '/gift-shop', label: 'Gift Shop' },
  { href: '/arcade', label: 'Arcade' },
  { href: '/museum', label: 'Museum' },
  { href: '/fortune', label: 'Fortune' },
  { href: '/chapel', label: 'Chapel' },
  { href: '/deep-garden', label: 'Garden' },
  { href: '/employees-only', label: 'Employees Only' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteURL}${ogImage}`} />
    <meta property="og:site_name" content="Lithium Dreams Industries" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteURL}${ogImage}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:ital,wght@0,400;0,600;1,400&family=IBM+Plex+Sans:ital,wght@0,400;0,600;1,400&family=Oswald:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Lithium Dreams Industries",
      "url": siteURL,
      "logo": `${siteURL}/favicon.svg`,
      "description": "Operational systems design studio, creative laboratory, and last roadside attraction at the edge of the universe.",
    })} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <nav class="site-nav">
      <a href="/" class="nav-logo">
        <span class="nav-logo-name">Lithium Dreams</span>
        <span class="nav-logo-sub">Industries</span>
      </a>
      <div class="nav-links" id="nav-links">
        {navLinks.map(link => (
          <a
            href={link.href}
            data-active={activePage === link.href ? 'true' : 'false'}
          >
            {link.label}
          </a>
        ))}
      </div>
      <div class="nav-end">
        <a href="/work" class="nav-badge" title="Lithium Dreams Industries — Work with us">LDI</a>
        <button
          class="nav-hamburger"
          id="nav-hamburger"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="nav-links"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <main class="page-content" id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="footer-name">Lithium Dreams Industries</span>
          <span class="footer-tagline mono text-dim">The Last Roadside Attraction</span>
        </div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="/attraction" class="mono text-dim">Midway</a>
          <a href="/museum" class="mono text-dim">Museum</a>
          <a href="/fortune" class="mono text-dim">Fortune</a>
          <a href="/chapel" class="mono text-dim">Chapel</a>
          <a href="/deep-garden" class="mono text-dim">Garden</a>
          <a href="/about" class="mono text-dim">About</a>
        </nav>
        <div class="footer-meta">
          <a href="/work" class="footer-corp mono text-dim">Operator Notes →</a>
          <span class="footer-copy mono text-dim">&copy; Lithium Dreams Industries &mdash; Cryptid activity not the responsibility of management</span>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .nav-logo {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    text-decoration: none;
  }
  .nav-logo-name {
    font-family: var(--font-sub);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--neon-amber);
    text-transform: uppercase;
  }
  .nav-logo-sub {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: rgba(232, 222, 200, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }
  .nav-badge {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    color: var(--neon-amber);
    border: 1px solid var(--neon-amber);
    padding: 0.2rem 0.5rem;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 0 6px var(--amber-glow);
    transition: color 0.2s, border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .nav-badge:hover {
    background: var(--neon-amber);
    color: var(--ldi-black);
    border-color: var(--neon-amber);
    box-shadow: 0 0 14px var(--amber-glow);
  }
  .site-footer {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: var(--space-lg) var(--space-xl);
  }
  .footer-inner {
    max-width: var(--content-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-xl);
    align-items: start;
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .footer-name {
    font-family: var(--font-sub);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(232,222,200,0.4);
    text-transform: uppercase;
  }
  .footer-tagline { font-size: 0.6rem; letter-spacing: 0.1em; }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .footer-nav a {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color 0.15s;
    text-transform: uppercase;
  }
  .footer-nav a:hover { color: var(--paper); }
  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-align: right;
  }
  .footer-corp {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .footer-corp:hover { color: var(--neon-amber); }
  .footer-copy { font-size: 0.6rem; letter-spacing: 0.04em; line-height: 1.5; }
  @media (max-width: 700px) {
    .footer-inner { grid-template-columns: 1fr; gap: var(--space-lg); }
    .footer-meta { text-align: left; }
  }
</style>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const navLinks = document.getElementById('nav-links');

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    navLinks?.classList.toggle('nav-links--open');
  });

  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      navLinks.classList.remove('nav-links--open');
    });
  });
</script>
