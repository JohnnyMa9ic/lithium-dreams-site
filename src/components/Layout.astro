---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  rainOnHero?: boolean;
  activePage?: string;
}

const {
  title = 'Lithium Dreams Industries',
  description = 'The Last Roadside Attraction. Cryptids. Arcade. Gift Shop. Weddings Tuesdays & Fridays.',
  activePage = '',
} = Astro.props;

const navLinks = [
  { href: '/attraction', label: 'Attraction' },
  { href: '/gift-shop', label: 'Gift Shop' },
  { href: '/arcade', label: 'Arcade' },
  { href: '/museum', label: 'Museum' },
  { href: '/fortune', label: 'Fortune' },
  { href: '/employees-only', label: 'Employees Only' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:ital,wght@0,400;0,600;1,400&family=IBM+Plex+Sans:ital,wght@0,400;0,600;1,400&family=Oswald:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <nav class="site-nav">
      <a href="/" class="nav-logo">
        <span class="nav-logo-name">Lithium Dreams</span>
        <span class="nav-logo-sub">Industries</span>
      </a>
      <div class="nav-links" id="nav-links">
        {navLinks.map(link => (
          <a
            href={link.href}
            data-active={activePage === link.href ? 'true' : 'false'}
          >
            {link.label}
          </a>
        ))}
      </div>
      <div class="nav-end">
        <a href="/work" class="nav-badge" title="Lithium Dreams Industries — Work with us">LDI</a>
        <button
          class="nav-hamburger"
          id="nav-hamburger"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="nav-links"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <main class="page-content" id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <span class="mono text-dim">Lithium Dreams Industries &mdash; All rights reserved &mdash; Cryptid activity not the responsibility of management</span>
    </footer>
  </body>
</html>

<style>
  .nav-logo {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    text-decoration: none;
  }
  .nav-logo-name {
    font-family: var(--font-sub);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--neon-amber);
    text-transform: uppercase;
  }
  .nav-logo-sub {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: rgba(232, 222, 200, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }
  .nav-badge {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    color: var(--neon-amber);
    border: 1px solid var(--neon-amber);
    padding: 0.2rem 0.5rem;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 0 6px var(--amber-glow);
    transition: color 0.2s, border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .nav-badge:hover {
    background: var(--neon-amber);
    color: var(--ldi-black);
    border-color: var(--neon-amber);
    box-shadow: 0 0 14px var(--amber-glow);
  }
  .site-footer {
    padding: var(--space-lg);
    text-align: center;
    border-top: var(--border-faint);
    font-size: 0.7rem;
  }
</style>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const navLinks = document.getElementById('nav-links');

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    navLinks?.classList.toggle('nav-links--open');
  });

  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      navLinks.classList.remove('nav-links--open');
    });
  });
</script>
