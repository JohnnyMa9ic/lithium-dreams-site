---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  activePage?: string;
}

const {
  title = 'LDI Glasshouse — Operational Systems Design',
  description = 'Lithium Dreams Industries designs practical operational systems for people and organizations who need clarity without complexity.',
  ogImage = '/studio-hero.png',
  activePage = '',
} = Astro.props;

const siteURL = 'https://lithium-dreams.com';
const canonicalURL = new URL(Astro.url.pathname, siteURL);

const navLinks = [
  { href: '/work', label: 'Overview' },
  { href: '/work/intake', label: 'Mission Intake' },
  { href: '/work/case-files', label: 'Case Files' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteURL}${ogImage}`} />
    <meta property="og:site_name" content="Lithium Dreams Industries" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteURL}${ogImage}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Lithium Dreams Industries",
      "url": siteURL,
      "logo": `${siteURL}/favicon.svg`,
      "description": "Operational systems design studio. Practical infrastructure for people and organizations who need clarity without complexity.",
    })} />
  </head>
  <body class="gh-body">
    <nav class="gh-nav">
      <a href="/work" class="gh-logo" aria-label="LDI Work">
        <span class="gh-logo-mark">LDI</span>
        <span class="gh-logo-name">Lithium Dreams Industries</span>
      </a>
      <div class="gh-nav-links">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={activePage === link.href ? 'active' : ''}
          >
            {link.label}
          </a>
        ))}
      </div>
      <a href="/attraction" class="gh-nav-escape">← The Attraction</a>
    </nav>

    <main class="gh-content">
      <slot />
    </main>

    <footer class="gh-footer">
      <div class="gh-footer-inner">
        <span class="gh-footer-brand">Lithium Dreams Industries</span>
        <span class="gh-footer-tag">Operating Systems Design</span>
        <a href="/about" class="gh-footer-about">About</a>
        <a href="/attraction" class="gh-footer-link">Visit the Attraction →</a>
      </div>
    </footer>

  </body>
</html>

<style>
  :root {
    --gh-bg: #eef1ec;
    --gh-glass: rgba(255, 255, 255, 0.70);
    --gh-text: #1a1d1a;
    --gh-muted: #5a5f58;
    --gh-faint: #8a8f88;
    --gh-blue: #3d7fbd;
    --gh-brass: #c99d4c;
    --gh-walnut: #8b6547;
    --gh-green: #9cad8d;
    --gh-silver: #9ba8b2;
    --gh-border: rgba(0, 0, 0, 0.10);
    --gh-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
    --gh-radius: 18px;
    --gh-max: 1180px;
    --gh-sans: 'Inter', ui-sans-serif, system-ui, sans-serif;
    --gh-serif: ui-serif, Georgia, 'Times New Roman', serif;
    --gh-mono: ui-monospace, 'SFMono-Regular', Consolas, monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  .gh-body {
    background: #F5F3EE;
    color: var(--gh-text);
    font-family: var(--gh-sans);
    font-size: 1rem;
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Nav ── */
  .gh-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.875rem 2rem;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--gh-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .gh-logo {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    text-decoration: none;
  }
  .gh-logo-mark {
    background: var(--gh-brass);
    color: #fff;
    font-family: var(--gh-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 0.35em 0.55em;
    line-height: 1;
    border-radius: 4px;
  }
  .gh-logo-name {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--gh-muted);
  }

  .gh-nav-links {
    display: flex;
    gap: 1.5rem;
    margin-left: 1rem;
  }
  .gh-nav-links a {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--gh-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .gh-nav-links a:hover { color: var(--gh-text); }
  .gh-nav-links a.active { color: var(--gh-blue); }

  .gh-nav-escape {
    margin-left: auto;
    font-size: 0.72rem;
    color: var(--gh-faint);
    text-decoration: none;
    transition: color 0.15s ease;
    font-family: var(--gh-mono);
    letter-spacing: 0.04em;
  }
  .gh-nav-escape:hover { color: var(--gh-muted); }

  /* ── Content ── */
  .gh-content {
    flex: 1;
    max-width: var(--gh-max);
    margin: 0 auto;
    padding: 3rem 2rem;
    width: 100%;
  }

  /* ── Footer ── */
  .gh-footer {
    border-top: 1px solid var(--gh-border);
    background: #ffffff;
    padding: 1.5rem 2rem;
  }
  .gh-footer-inner {
    max-width: var(--gh-max);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.75rem;
  }
  .gh-footer-brand { font-weight: 600; color: var(--gh-text); }
  .gh-footer-tag { color: var(--gh-faint); }
  .gh-footer-about {
    color: var(--gh-faint);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .gh-footer-about:hover { color: var(--gh-muted); }
  .gh-footer-link {
    margin-left: auto;
    color: var(--gh-faint);
    text-decoration: none;
    font-family: var(--gh-mono);
    letter-spacing: 0.04em;
    transition: color 0.15s ease;
  }
  .gh-footer-link:hover { color: var(--gh-muted); }

  @media (max-width: 768px) {
    .gh-nav { padding: 0.875rem 1rem; flex-wrap: wrap; gap: 0.75rem; }
    .gh-nav-links { margin-left: 0; gap: 1rem; }
    .gh-nav-escape { display: none; }
    .gh-content { padding: 2rem 1rem; }
    .gh-footer { padding: 1.25rem 1rem; }
    .gh-footer-link { display: none; }
  }
</style>
